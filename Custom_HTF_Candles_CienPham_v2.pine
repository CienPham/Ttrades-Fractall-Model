// Modified by shiine4x — added free-form custom timeframe input (e.g. 27m, 81m, 420m)
// v2 by CienPham — added Daily Profile (P1/P1B/P2/P3/P4/P4B), Asia/London Range boxes,
//                  7H candle highlight, P2/P3 sweep alert, dashboard table

//@version=6
indicator('Custom HTF Candles [CienPham] v2', overlay = true,
     max_boxes_count  = 500,
     max_lines_count  = 500,
     max_labels_count = 500,
     max_bars_back    = 5000)

// ═══════════════════════════════════════════════════════════════
// TYPE DEFINITIONS
// ═══════════════════════════════════════════════════════════════

type Candle
    float o
    float c
    float h
    float l
    int   o_time
    int   o_idx
    int   c_idx
    int   h_idx
    int   l_idx
    string dow
    box    body
    line   wick_up
    line   wick_down
    label  dow_label

type Trace
    line  o
    line  c
    line  h
    line  l
    label o_l
    label c_l
    label h_l
    label l_l

type Imbalance
    box b
    int idx

type CandleSettings
    bool   show
    string htf
    int    max_display

type Settings
    int    max_sets
    color  bull_body
    color  bull_border
    color  bull_wick
    color  bear_body
    color  bear_border
    color  bear_wick
    int    offset
    int    buffer
    int    htf_buffer
    int    width
    bool   use_custom_daily
    string custom_daily
    bool   daily_name
    bool   trace_show
    color  trace_o_color
    string trace_o_style
    int    trace_o_size
    color  trace_c_color
    string trace_c_style
    int    trace_c_size
    color  trace_h_color
    string trace_h_style
    int    trace_h_size
    color  trace_l_color
    string trace_l_style
    int    trace_l_size
    string trace_anchor
    bool   label_show
    color  label_color
    string label_size
    bool   htf_label_show
    color  htf_label_color
    string htf_label_size
    bool   htf_timer_show
    color  htf_timer_color
    string htf_timer_size
    string label_position
    string label_alignment
    color  dow_color
    string dow_size
    bool   fvg_show
    color  fvg_color
    bool   vi_show
    color  vi_color

type CandleSet
    array<Candle>     candles
    array<Imbalance>  imbalances
    CandleSettings    settings
    label             tfNameTop
    label             tfNameBottom
    label             tfTimerTop
    label             tfTimerBottom

type Helper
    string name = 'Helper'

// ═══════════════════════════════════════════════════════════════
// GLOBAL OBJECTS
// ═══════════════════════════════════════════════════════════════

Settings settings = Settings.new()
Helper   helper   = Helper.new()
var Trace trace   = Trace.new()
color color_transparent = #ffffff00

var CandleSettings settingsHTF1 = CandleSettings.new()
var CandleSettings settingsHTF2 = CandleSettings.new()
var CandleSettings settingsHTF3 = CandleSettings.new()

var array<Candle>    candles1    = array.new<Candle>()
var array<Candle>    candles2    = array.new<Candle>()
var array<Candle>    candles3    = array.new<Candle>()
var array<Imbalance> imbalances1 = array.new<Imbalance>()
var array<Imbalance> imbalances2 = array.new<Imbalance>()
var array<Imbalance> imbalances3 = array.new<Imbalance>()

var CandleSet htf1 = CandleSet.new()
htf1.settings    := settingsHTF1
htf1.candles     := candles1
htf1.imbalances  := imbalances1

var CandleSet htf2 = CandleSet.new()
htf2.settings    := settingsHTF2
htf2.candles     := candles2
htf2.imbalances  := imbalances2

var CandleSet htf3 = CandleSet.new()
htf3.settings    := settingsHTF3
htf3.candles     := candles3
htf3.imbalances  := imbalances3

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════

string group_source    = 'HTF Source'
string group_style     = 'Styling'
string group_label     = 'Label Settings'
string group_imbalance = 'Imbalance'
string group_trace     = 'Trace'
string group_session   = 'Session Ranges & Profile'

// ── HTF 1 ──────────────────────────────────────────────────────
htf1.settings.show        := input.bool(true, 'HTF 1', inline = 'htf1', group = group_source)
htf1_mode                  = input.string('Preset', 'Mode', options = ['Preset', 'Custom'], inline = 'htf1m', group = group_source)
htf1_preset                = input.timeframe('1D', 'Preset', inline = 'htf1m', group = group_source)
htf1_custom_str            = input.string('27', 'Phút tùy chỉnh (vd: 27, 81, 420)', inline = 'htf1c', group = group_source)
htf1.settings.max_display := input.int(4, '', minval = 1, maxval = 100, inline = 'htf1', group = group_source)

string htf1_cleaned = str.replace_all(str.lower(htf1_custom_str), 'm', '')
string htf_1        = htf1_mode == 'Preset' ? htf1_preset : htf1_cleaned
htf1.settings.htf  := htf_1

// ── HTF 2 ──────────────────────────────────────────────────────
htf2.settings.show        := input.bool(true, 'HTF 2', inline = 'htf2', group = group_source)
htf2_mode                  = input.string('Preset', 'Mode', options = ['Preset', 'Custom'], inline = 'htf2m', group = group_source)
htf2_preset                = input.timeframe('240', 'Preset', inline = 'htf2m', group = group_source)
htf2_custom_str            = input.string('81', 'Phút tùy chỉnh (vd: 27, 81, 420)', inline = 'htf2c', group = group_source)
htf2.settings.max_display := input.int(4, '', minval = 1, maxval = 100, inline = 'htf2', group = group_source)

string htf2_cleaned = str.replace_all(str.lower(htf2_custom_str), 'm', '')
string htf_2        = htf2_mode == 'Preset' ? htf2_preset : htf2_cleaned
htf2.settings.htf  := htf_2

// ── HTF 3 ──────────────────────────────────────────────────────
htf3.settings.show        := input.bool(true, 'HTF 3', inline = 'htf3', group = group_source)
htf3_mode                  = input.string('Preset', 'Mode', options = ['Preset', 'Custom'], inline = 'htf3m', group = group_source)
htf3_preset                = input.timeframe('1W', 'Preset', inline = 'htf3m', group = group_source)
htf3_custom_str            = input.string('420', 'Phút tùy chỉnh (vd: 27, 81, 420)', inline = 'htf3c', group = group_source)
htf3.settings.max_display := input.int(4, '', minval = 1, maxval = 100, inline = 'htf3', group = group_source)

string htf3_cleaned = str.replace_all(str.lower(htf3_custom_str), 'm', '')
string htf_3        = htf3_mode == 'Preset' ? htf3_preset : htf3_cleaned
htf3.settings.htf  := htf_3

// ── General ────────────────────────────────────────────────────
settings.max_sets := input.int(3, 'Show up to N HTFs', minval = 1, maxval = 3, group = group_source)

settings.use_custom_daily := input.bool(false, 'Custom daily candle open', inline = 'customdaily', group = group_source)
settings.custom_daily     := input.string('Midnight', '', options = ['Midnight', '8:30', '9:30'], inline = 'customdaily', group = group_source)

settings.bull_body   := input.color(#ffffff,           'Bull Body',  inline = 'body',    group = group_style)
settings.bear_body   := input.color(#4d4d4d,           '',           inline = 'body',    group = group_style)
settings.bull_border := input.color(#000000,           'Borders',    inline = 'borders', group = group_style)
settings.bear_border := input.color(#000000,           '',           inline = 'borders', group = group_style)
settings.bull_wick   := input.color(#000000,           'Wick',       inline = 'wick',    group = group_style)
settings.bear_wick   := input.color(#000000,           '',           inline = 'wick',    group = group_style)

settings.offset     := input.int(10, 'Padding from current candles', minval = 1, group = group_style)
settings.buffer     := input.int(1,  'Space between candles',        minval = 1, maxval = 4,  group = group_style)
settings.htf_buffer := input.int(6,  'Space between HTF groups',     minval = 1, maxval = 20, group = group_style)
settings.width      := input.int(1,  'Candle Width',                 minval = 1, maxval = 4,  group = group_style) * 2

settings.htf_label_show  := input.bool(true,        'HTF Label',        group = group_label, inline = 'HTFlabel')
settings.htf_label_color := input.color(#000000,    '',                 group = group_label, inline = 'HTFlabel')
settings.htf_label_size  := input.string(size.large, '', [size.tiny, size.small, size.normal, size.large, size.huge], group = group_label, inline = 'HTFlabel')

settings.label_position  := 'Top'
settings.label_alignment := input.string('Align', 'Label Alignment', options = ['Align', 'Follow Candles'], group = group_label)

settings.htf_timer_show  := input.bool(true,        'Remaining time', inline = 'timer', group = group_label)
settings.htf_timer_color := input.color(#000000,    '',               inline = 'timer', group = group_label)
settings.htf_timer_size  := input.string(size.normal, '', [size.tiny, size.small, size.normal, size.large, size.huge], group = group_label, inline = 'timer')

settings.daily_name := input.bool(false, 'Interval Value', group = group_label, inline = 'dow')
settings.dow_color  := input.color(#000000, '',             group = group_label, inline = 'dow')
settings.dow_size   := input.string(size.small, '', [size.tiny, size.small, size.normal, size.large, size.huge], group = group_label, inline = 'dow')

settings.fvg_show  := input.bool(false, 'Fair Value Gap',    group = group_imbalance, inline = 'fvg')
settings.fvg_color := input.color(color.new(color.gray, 80), '', inline = 'fvg', group = group_imbalance)

settings.vi_show  := input.bool(false, 'Volume Imbalance',           group = group_imbalance, inline = 'vi')
settings.vi_color := input.color(color.new(color.red, 50), '', inline = 'vi', group = group_imbalance)

settings.trace_show    := input.bool(false, 'Trace lines', group = group_trace)
settings.trace_o_color := input.color(color.new(color.gray, 50), 'Open',  inline = '1', group = group_trace)
settings.trace_o_style := input.string('....', '', options = ['Solid', '----', '....'], inline = '1', group = group_trace)
settings.trace_o_size  := input.int(1, '', options = [1, 2, 3, 4], inline = '1', group = group_trace)
settings.trace_c_color := input.color(color.new(color.gray, 50), 'Close', inline = '2', group = group_trace)
settings.trace_c_style := input.string('....', '', options = ['Solid', '----', '....'], inline = '2', group = group_trace)
settings.trace_c_size  := input.int(1, '', options = [1, 2, 3, 4], inline = '2', group = group_trace)
settings.trace_h_color := input.color(color.new(color.gray, 50), 'High',  inline = '3', group = group_trace)
settings.trace_h_style := input.string('....', '', options = ['Solid', '----', '....'], inline = '3', group = group_trace)
settings.trace_h_size  := input.int(1, '', options = [1, 2, 3, 4], inline = '3', group = group_trace)
settings.trace_l_color := input.color(color.new(color.gray, 50), 'Low',   inline = '4', group = group_trace)
settings.trace_l_style := input.string('....', '', options = ['Solid', '----', '....'], inline = '4', group = group_trace)
settings.trace_l_size  := input.int(1, '', options = [1, 2, 3, 4], inline = '4', group = group_trace)
settings.trace_anchor  := input.string('First Timeframe', 'Anchor to', options = ['First Timeframe', 'Last Timeframe'], group = group_trace)

settings.label_show  := input.bool(false, 'Price Label', inline = 'label', group = group_trace)
settings.label_color := input.color(#000000, '', inline = 'label', group = group_trace)
settings.label_size  := input.string(size.small, '', [size.tiny, size.small, size.normal, size.large, size.huge], inline = 'label', group = group_trace)

// ── Session Range & Profile inputs ─────────────────────────────
bool   show_asia        = input.bool(true,  'Asia Range',    inline = 'asia',   group = group_session)
color  asia_color       = input.color(color.new(#2962FF, 88), '',               inline = 'asia',   group = group_session)
bool   show_london      = input.bool(true,  'London Range',  inline = 'london', group = group_session)
color  london_color     = input.color(color.new(#FF6D00, 88), '',               inline = 'london', group = group_session)
bool   show_7h          = input.bool(true,  'Highlight 7H candle (Asia+London setup)', group = group_session)
color  color_7h         = input.color(color.new(#9C27B0, 75), '',               inline = 'h7',     group = group_session)
bool   show_profile_lbl = input.bool(true,  'Daily Profile label on chart',      group = group_session)
bool   show_dashboard   = input.bool(true,  'Show Dashboard table',              group = group_session)
int    dash_x           = input.int(2,  'Table X offset (cols from right)', minval = 1, maxval = 10, group = group_session)
int    dash_y           = input.int(10, 'Table Y offset (rows from top)',   minval = 1, maxval = 20, group = group_session)
int    profile_history  = input.int(5,  'Profile history rows',             minval = 1, maxval = 10, group = group_session)
bool   alert_p2p3       = input.bool(true,  'Alert on P2/P3 sweep',         group = group_session)

// ═══════════════════════════════════════════════════════════════
// SESSION TIME HELPERS  (all times in America/New_York)
// ═══════════════════════════════════════════════════════════════

// Asia  : 6:00 PM – 11:59 PM  ET  (previous day 18:00 → 23:59)
// London: 1:00 AM – 7:59 AM   ET
// NY    : 8:00 AM – 4:59 PM   ET
// 7H candle: 6 PM ET → 1 AM ET  (Asia open through London open)

f_inSession(string sess) =>
    not na(time(timeframe.period, sess, 'America/New_York'))

bool isAsia   = f_inSession('1800-2359')
bool isLondon = f_inSession('0100-0759')
bool isNY     = f_inSession('0800-1659')
bool is7H     = f_inSession('1800-0059')   // 6 PM → midnight portion
bool is7H_b   = f_inSession('0000-0059')   // midnight → 1 AM portion
bool in7H     = is7H or is7H_b

// ── Detect session transitions ──────────────────────────────────
bool newAsia   = isAsia   and not isAsia[1]
bool newLondon = isLondon and not isLondon[1]
bool newNY     = isNY     and not isNY[1]
bool new7H     = in7H     and not in7H[1]

// ═══════════════════════════════════════════════════════════════
// SESSION RANGE TRACKING
// ═══════════════════════════════════════════════════════════════

var float  asia_high   = na,   var float  asia_low   = na
var int    asia_start  = na,   var int    asia_end   = na
var float  lon_high    = na,   var float  lon_low    = na
var int    lon_start   = na,   var int    lon_end    = na

// Boxes drawn once per session (deleted & redrawn on update)
var box    asia_box    = na
var box    london_box  = na

// ── Asia range ──────────────────────────────────────────────────
if newAsia
    asia_high  := high
    asia_low   := low
    asia_start := bar_index
    asia_end   := bar_index

if isAsia
    asia_high  := math.max(asia_high, high)
    asia_low   := math.min(asia_low,  low)
    asia_end   := bar_index

// ── London range ───────────────────────────────────────────────
if newLondon
    lon_high   := high
    lon_low    := low
    lon_start  := bar_index
    lon_end    := bar_index

if isLondon
    lon_high   := math.max(lon_high, high)
    lon_low    := math.min(lon_low,  low)
    lon_end    := bar_index

// ── Draw/update Asia box ────────────────────────────────────────
if show_asia and barstate.islast
    if not na(asia_box)
        box.delete(asia_box)
    if not na(asia_start)
        asia_box := box.new(asia_start, asia_high, asia_end + 1, asia_low,
             border_color = color.new(#2962FF, 60),
             border_width = 1,
             bgcolor      = asia_color,
             xloc         = xloc.bar_index)

// ── Draw/update London box ──────────────────────────────────────
if show_london and barstate.islast
    if not na(london_box)
        box.delete(london_box)
    if not na(lon_start)
        london_box := box.new(lon_start, lon_high, lon_end + 1, lon_low,
             border_color = color.new(#FF6D00, 60),
             border_width = 1,
             bgcolor      = london_color,
             xloc         = xloc.bar_index)

// ── 7H candle body background ───────────────────────────────────
var float h7_high  = na,  var float h7_low   = na
var int   h7_start = na,  var int   h7_end   = na
var box   h7_box   = na

if new7H
    h7_high  := high
    h7_low   := low
    h7_start := bar_index
    h7_end   := bar_index

if in7H
    h7_high  := math.max(h7_high, high)
    h7_low   := math.min(h7_low,  low)
    h7_end   := bar_index

if show_7h and barstate.islast
    if not na(h7_box)
        box.delete(h7_box)
    if not na(h7_start)
        h7_box := box.new(h7_start, h7_high, h7_end + 1, h7_low,
             border_color = color.new(#9C27B0, 50),
             border_width = 1,
             bgcolor      = color_7h,
             xloc         = xloc.bar_index)

// ═══════════════════════════════════════════════════════════════
// DAILY PROFILE CLASSIFICATION
// Logic: compare Asia direction, London sweep behaviour, NY direction
//
// Asia direction  = close vs open of Asia session
// London vs Asia  = does London sweep high/low of Asia?
// NY direction    = direction from London close through NY
//
// P1   — Asia bull + London bull + NY bull  (same direction all 3)
// P1B  — Asia bull + London sideways + NY bull
// P2   — London sweeps Asia high/low then reverses; NY follows London
// P3   — Asia+London sideways, 8AM bar sweeps both, NY reverses hard
// P4   — Asia+London same dir, NY sweeps then reverses (trap)
// P4B  — Asia+London same dir, NY reverses without sweep
// ═══════════════════════════════════════════════════════════════

// Capture session OHLC via request.security is not available mid-bar,
// so we track them manually bar by bar.

var float asia_open  = na,  var float asia_close = na
var float lon_open   = na,  var float lon_close  = na
var float ny_open    = na,  var float ny_close   = na
var float ny_high    = na,  var float ny_low     = na

if newAsia
    asia_open  := open
if isAsia
    asia_close := close

if newLondon
    lon_open   := open
if isLondon
    lon_close  := close

if newNY
    ny_open    := open
    ny_high    := high
    ny_low     := low
if isNY
    ny_close   := close
    ny_high    := math.max(ny_high, high)
    ny_low     := math.min(ny_low, low)

// ── Profile history arrays ──────────────────────────────────────
var array<string> profile_hist   = array.new<string>()
var array<int>    profile_time   = array.new<int>()
var label         profile_label  = na

// ── Classify at end of NY session ──────────────────────────────
bool endNY = not isNY and isNY[1]

string today_profile = 'n/a'
string p_color_str   = '#888888'

// We classify on the bar right after NY closes
if endNY and not na(asia_open) and not na(lon_open) and not na(ny_open)
    float asia_dir   = asia_close - asia_open         // + bull, - bear
    float london_dir = lon_close  - lon_open
    float ny_dir     = ny_close   - ny_open

    // Did London sweep Asia's high or low?
    bool lon_swept_high = lon_high > asia_high
    bool lon_swept_low  = lon_low  < asia_low
    bool lon_sweep      = lon_swept_high or lon_swept_low

    // Did London reverse after sweep? (opposite direction vs sweep)
    bool lon_reversed   = lon_sweep and (lon_swept_high and london_dir < 0) or (lon_swept_low and london_dir > 0)

    // Is London sideways? (range < 30% of Asia range)
    float asia_range = asia_high - asia_low
    bool  lon_side   = asia_range > 0 and math.abs(london_dir) < asia_range * 0.3

    // Did NY sweep London's high/low then reverse?
    bool ny_swept_lon_high = ny_high > lon_high and ny_dir < 0
    bool ny_swept_lon_low  = ny_low  < lon_low  and ny_dir > 0
    bool ny_sweep_rev      = ny_swept_lon_high or ny_swept_lon_low

    // 8AM bar (first NY bar) — did it sweep both Asia+London?
    // We approximate: if NY high > both highs or NY low < both lows at open
    bool p3_cond = (math.abs(asia_dir) < asia_range * 0.35) and
                   (math.abs(london_dir) < asia_range * 0.35) and
                   ny_sweep_rev

    string profile = 'n/a'

    if p3_cond
        profile := 'P3'
    else if lon_reversed
        profile := 'P2'
    else if ny_sweep_rev
        profile := 'P4'
    else if (asia_dir > 0 and london_dir > 0 and ny_dir > 0) or
            (asia_dir < 0 and london_dir < 0 and ny_dir < 0)
        if lon_side
            profile := 'P1B'
        else
            profile := 'P1'
    else if (asia_dir > 0 and london_dir > 0 and ny_dir < 0) or
            (asia_dir < 0 and london_dir < 0 and ny_dir > 0)
        profile := 'P4B'
    else
        profile := 'P4B'   // catch-all for ambiguous days

    array.unshift(profile_hist, profile)
    array.unshift(profile_time, time)
    if array.size(profile_hist) > profile_history
        array.pop(profile_hist)
        array.pop(profile_time)

// ── Profile label on chart ──────────────────────────────────────
if show_profile_lbl and barstate.islast and array.size(profile_hist) > 0
    string lbl_txt = array.get(profile_hist, 0)
    color  lbl_col = switch lbl_txt
        'P1'  => #1565C0
        'P1B' => #1976D2
        'P2'  => #E65100
        'P3'  => #B71C1C
        'P4'  => #6A1B9A
        'P4B' => #880E4F
        =>       #555555

    if not na(profile_label)
        label.delete(profile_label)
    profile_label := label.new(bar_index, high * 1.0002,
         lbl_txt,
         xloc      = xloc.bar_index,
         color     = color.new(lbl_col, 20),
         textcolor = color.white,
         style     = label.style_label_down,
         size      = size.normal)

// ═══════════════════════════════════════════════════════════════
// P2 / P3 SWEEP ALERT
// Fires on the bar where London breaks Asia's high/low and then
// shows first sign of reversal (close opposite side of the sweep)
// ═══════════════════════════════════════════════════════════════

bool p2_alert_cond = false
bool p3_alert_cond = false

if alert_p2p3 and isLondon and not na(asia_high) and not na(asia_low)
    // P2: London sweeps Asia high and closes back below Asia high (bearish sweep)
    if high > asia_high and close < asia_high
        p2_alert_cond := true
    // P2: London sweeps Asia low and closes back above Asia low (bullish sweep)
    if low < asia_low and close > asia_low
        p2_alert_cond := true

if alert_p2p3 and isNY and not na(asia_high) and not na(asia_low)
    // P3: NY bar sweeps above both Asia+London highs and closes lower
    if high > math.max(asia_high, lon_high) and low < math.min(asia_low, lon_low) and close < open
        p3_alert_cond := true
    if high > math.max(asia_high, lon_high) and low < math.min(asia_low, lon_low) and close > open
        p3_alert_cond := true

alertcondition(p2_alert_cond, 'P2 London Sweep', '🔔 P2 — London đã quét thanh khoản Asia và đảo chiều!')
alertcondition(p3_alert_cond, 'P3 NY Sweep',     '🔔 P3 — NY quét cả Asia+London, chuẩn bị đảo chiều mạnh!')

// ═══════════════════════════════════════════════════════════════
// DASHBOARD TABLE
// ═══════════════════════════════════════════════════════════════

var table dash = na

f_profileColor(string p) =>
    switch p
        'P1'  => #1565C0
        'P1B' => #1976D2
        'P2'  => #E65100
        'P3'  => #B71C1C
        'P4'  => #6A1B9A
        'P4B' => #880E4F
        =>       #555555

f_profileDesc(string p) =>
    switch p
        'P1'  => 'Trend đồng nhất 3 phiên'
        'P1B' => 'London tích lũy, NY theo Asia'
        'P2'  => 'London quét Asia, NY theo London'
        'P3'  => 'Asia+Lon sideways, NY đảo mạnh'
        'P4'  => 'NY quét London rồi đảo (bẫy)'
        'P4B' => 'NY đảo trực tiếp (khó đoán)'
        =>       '—'

if show_dashboard and (barstate.islast or barstate.isrealtime)
    int  total_rows = 3 + math.min(array.size(profile_hist), profile_history)
    if na(dash) or true
        if not na(dash)
            table.delete(dash)
        dash := table.new(position.top_right, 3, total_rows,
             bgcolor      = color.new(#121212, 15),
             border_width = 1,
             border_color = color.new(color.white, 70),
             frame_width  = 1,
             frame_color  = color.new(color.white, 60))

    // Header row
    table.cell(dash, 0, 0, '📊 Daily Profile',
         text_color = color.white, text_size = size.small,
         bgcolor = color.new(#1A237E, 20), text_halign = text.align_center)
    table.merge_cells(dash, 0, 0, 2, 0)

    // Column headers
    table.cell(dash, 0, 1, 'Ngày',    text_color = #90CAF9, text_size = size.tiny, bgcolor = color.new(#0D47A1, 30))
    table.cell(dash, 1, 1, 'Profile', text_color = #90CAF9, text_size = size.tiny, bgcolor = color.new(#0D47A1, 30))
    table.cell(dash, 2, 1, 'Mô tả',   text_color = #90CAF9, text_size = size.tiny, bgcolor = color.new(#0D47A1, 30))

    // Current session info row
    string cur_asia_info = not na(asia_high) ?
         '↑' + str.tostring(math.round(asia_high, 2)) + ' ↓' + str.tostring(math.round(asia_low, 2)) : '—'

    table.cell(dash, 0, 2, 'Asia Now', text_color = #90CAF9, text_size = size.tiny, bgcolor = color.new(#0D47A1, 50))
    table.cell(dash, 1, 2, cur_asia_info, text_color = color.white, text_size = size.tiny, bgcolor = color.new(#0D47A1, 50))
    table.cell(dash, 2, 2, isAsia ? '🟢 Active' : isLondon ? '🟠 London' : isNY ? '🔵 NY' : '⚪ Closed',
         text_color = color.white, text_size = size.tiny, bgcolor = color.new(#0D47A1, 50))

    // History rows
    int hist_size = array.size(profile_hist)
    for i = 0 to math.min(hist_size - 1, profile_history - 1) by 1
        string p    = array.get(profile_hist, i)
        int    pt   = array.get(profile_time, i)
        string dstr = str.format_time(pt, 'MM/dd', 'America/New_York')
        color  pc   = f_profileColor(p)
        string desc = f_profileDesc(p)
        int    row  = i + 3

        table.cell(dash, 0, row, dstr,  text_color = color.new(color.white, 20), text_size = size.tiny, bgcolor = color.new(#1A1A2E, 30))
        table.cell(dash, 1, row, p,     text_color = color.white, text_size = size.small, bgcolor = color.new(pc, 30))
        table.cell(dash, 2, row, desc,  text_color = color.new(color.white, 20), text_size = size.tiny, bgcolor = color.new(#1A1A2E, 30))

// ═══════════════════════════════════════════════════════════════
// ORIGINAL METHODS (unchanged from base indicator)
// ═══════════════════════════════════════════════════════════════

method LineStyle(Helper helper, string style) =>
    helper.name := style
    out = switch style
        '----' => line.style_dashed
        '....' => line.style_dotted
        => line.style_solid
    out

method DayofWeek(Helper helper, int index) =>
    helper.name := 'DOW'
    switch
        index == 1 => 'M'
        index == 2 => 'T'
        index == 3 => 'W'
        index == 4 => 'T'
        index == 5 => 'F'
        index == 6 => 'S'
        index == 7 => 'S'
        na(index)  => ''

method NormalizeHTF(Helper helper, string HTF) =>
    helper.name := 'NormalizeHTF'
    string normalized = str.upper(HTF)
    int    len        = str.length(normalized)
    if len > 1 and str.substring(normalized, len - 1, len) == 'H'
        string hoursText = str.substring(normalized, 0, len - 1)
        float  hours     = str.tonumber(hoursText)
        if not na(hours)
            normalized := str.tostring(int(hours * 60))
    normalized

method ValidTimeframe(Helper helper, string HTF) =>
    helper.name := HTF
    string _htf = helper.NormalizeHTF(HTF)
    if timeframe.in_seconds(_htf) >= timeframe.in_seconds('D') and timeframe.in_seconds(_htf) > timeframe.in_seconds()
        true
    else
        n1 = timeframe.in_seconds()
        n2 = timeframe.in_seconds(_htf)
        n1 < n2 and math.round(n2 / n1) == n2 / n1

method RemainingTime(Helper helper, string HTF) =>
    helper.name := HTF
    string _htf = helper.NormalizeHTF(HTF)
    if barstate.isrealtime
        timeRemaining = (time_close(_htf) - timenow) / 1000
        days    = math.floor(timeRemaining / 86400)
        hours   = math.floor((timeRemaining - days * 86400) / 3600)
        minutes = math.floor((timeRemaining - days * 86400 - hours * 3600) / 60)
        seconds = math.floor(timeRemaining - days * 86400 - hours * 3600 - minutes * 60)
        r = str.tostring(seconds, '00')
        if minutes > 0 or hours > 0 or days > 0
            r := str.tostring(minutes, '00') + ':' + r
        if hours > 0 or days > 0
            r := str.tostring(hours, '00') + ':' + r
        if days > 0
            r := str.tostring(days) + 'D ' + r
        r
    else
        'n/a'

method HTFName(Helper helper, string HTF) =>
    helper.name := 'HTFName'
    string _htf   = helper.NormalizeHTF(HTF)
    formatted     = HTF
    seconds       = timeframe.in_seconds(_htf)
    if seconds < 60
        formatted := str.tostring(seconds) + 's'
    else if seconds / 60 < 60
        formatted := str.tostring(seconds / 60) + 'm'
    else if seconds / 60 / 60 < 24
        formatted := str.tostring(seconds / 60 / 60) + 'H'
    else if seconds / 60 / 60 / 24 < 7
        formatted := str.tostring(seconds / 60 / 60 / 24) + 'D'
    else
        formatted := HTF
    formatted

method HTFEnabled(Helper helper) =>
    helper.name := 'HTFEnabled'
    int enabled = 0
    enabled := enabled + (htf1.settings.show ? 1 : 0)
    enabled := enabled + (htf2.settings.show ? 1 : 0)
    enabled := enabled + (htf3.settings.show ? 1 : 0)
    math.min(enabled, settings.max_sets)

method CandleSetHigh(Helper helper, array<Candle> _candles, float h) =>
    helper.name := 'CandlesSetHigh'
    float _h = h
    if array.size(_candles) > 0
        for i = 0 to array.size(_candles) - 1 by 1
            Candle c = array.get(_candles, i)
            if c.h > _h
                _h := c.h
    _h

method CandleSetLow(Helper helper, array<Candle> _candles, float l) =>
    helper.name := 'CandlesSetLow'
    float _l = l
    if array.size(_candles) > 0
        for i = 0 to array.size(_candles) - 1 by 1
            Candle c = array.get(_candles, i)
            if c.l < _l
                _l := c.l
    _l

method CandlesHigh(Helper helper, array<Candle> _candles) =>
    helper.name := 'CandlesHigh'
    h   = 0.0
    int cnt  = 0
    int last = helper.HTFEnabled()
    if htf1.settings.show and helper.ValidTimeframe(htf1.settings.htf)
        h   := helper.CandleSetHigh(htf1.candles, h)
        cnt := cnt + 1
    if htf2.settings.show and helper.ValidTimeframe(htf2.settings.htf) and cnt < last
        h   := helper.CandleSetHigh(htf2.candles, h)
        cnt := cnt + 1
    if htf3.settings.show and helper.ValidTimeframe(htf3.settings.htf) and cnt < last
        h   := helper.CandleSetHigh(htf3.candles, h)
    if array.size(_candles) > 0
        for i = 0 to array.size(_candles) - 1 by 1
            Candle c = array.get(_candles, i)
            if c.h > h
                h := c.h
    h

method CandlesLow(Helper helper, array<Candle> _candles, float h) =>
    helper.name := 'CandlesLow'
    l   = h
    int cnt  = 0
    int last = helper.HTFEnabled()
    if htf1.settings.show and helper.ValidTimeframe(htf1.settings.htf)
        l   := helper.CandleSetLow(htf1.candles, l)
        cnt := cnt + 1
    if htf2.settings.show and helper.ValidTimeframe(htf2.settings.htf) and cnt < last
        l   := helper.CandleSetLow(htf2.candles, l)
        cnt := cnt + 1
    if htf3.settings.show and helper.ValidTimeframe(htf3.settings.htf) and cnt < last
        l   := helper.CandleSetLow(htf3.candles, l)
    if array.size(_candles) > 0
        for i = 0 to array.size(_candles) - 1 by 1
            Candle c = array.get(_candles, i)
            if c.l < l
                l := c.l
    l

method UpdateTime(CandleSet candleSet) =>
    if settings.htf_timer_show and (barstate.isrealtime or barstate.islast)
        string tmr = '(' + helper.RemainingTime(candleSet.settings.htf) + ')'
        if not na(candleSet.tfTimerTop)
            candleSet.tfTimerTop.set_text(tmr)
        if not na(candleSet.tfTimerBottom)
            candleSet.tfTimerBottom.set_text(tmr)
    candleSet

method Reorder(CandleSet candleSet, int offset) =>
    size = candleSet.candles.size()
    if size > 0
        for i = size - 1 to 0 by 1
            Candle candle = candleSet.candles.get(i)
            t_buffer = offset + (settings.width + settings.buffer) * (size - i - 1)
            box.set_left(candle.body,   bar_index + t_buffer)
            box.set_right(candle.body,  bar_index + settings.width + t_buffer)
            line.set_x1(candle.wick_up,   bar_index + settings.width / 2 + t_buffer)
            line.set_x2(candle.wick_up,   bar_index + settings.width / 2 + t_buffer)
            line.set_x1(candle.wick_down, bar_index + settings.width / 2 + t_buffer)
            line.set_x2(candle.wick_down, bar_index + settings.width / 2 + t_buffer)
            if settings.daily_name
                if not na(candle.dow_label)
                    candle.dow_label.set_y(candle.h)
                    candle.dow_label.set_x(bar_index + settings.width / 2 + t_buffer)
                    candle.dow_label.set_text(candle.dow)
                else
                    candle.dow_label := label.new(bar_index + settings.width / 2 + t_buffer, candle.h, candle.dow, color = color_transparent, textcolor = settings.dow_color, style = label.style_label_down, size = settings.dow_size)

    top    = 0.0
    bottom = 0.0
    if settings.label_alignment == 'Align'
        top    := helper.CandlesHigh(candleSet.candles)
        bottom := helper.CandlesLow(candleSet.candles, top)
    if settings.label_alignment == 'Follow Candles'
        top    := helper.CandleSetHigh(candleSet.candles, 0)
        bottom := helper.CandleSetLow(candleSet.candles, top)

    left = bar_index + offset + (settings.width + settings.buffer) * (size - 1) / 2

    if settings.htf_label_show
        string lblt = helper.HTFName(candleSet.settings.htf)
        string lbll = lblt
        if settings.htf_timer_show
            lblt := lblt + '\n'
            lbll := '\n' + lbll
        if settings.daily_name
            lblt := lblt + '\n'
        string tmr = '(' + helper.RemainingTime(candleSet.settings.htf) + ')' + (settings.daily_name ? '\n' : '')
        if settings.htf_timer_show
            if not na(candleSet.tfTimerTop)
                candleSet.tfTimerTop.set_xy(left, top)
            else
                candleSet.tfTimerTop := label.new(left, top, tmr, color = color_transparent, textcolor = settings.htf_timer_color, style = label.style_label_down, size = settings.htf_timer_size)
        else
            if not na(candleSet.tfTimerTop)
                label.delete(candleSet.tfTimerTop)
                candleSet.tfTimerTop := na
        if not na(candleSet.tfNameTop)
            candleSet.tfNameTop.set_xy(left, top)
        else
            candleSet.tfNameTop := label.new(left, top, lblt, color = color_transparent, textcolor = settings.htf_label_color, style = label.style_label_down, size = settings.htf_label_size)
        if not na(candleSet.tfNameBottom)
            label.delete(candleSet.tfNameBottom)
            candleSet.tfNameBottom := na
        if not na(candleSet.tfTimerBottom)
            label.delete(candleSet.tfTimerBottom)
            candleSet.tfTimerBottom := na
    else
        if not na(candleSet.tfNameTop)
            label.delete(candleSet.tfNameTop)
            candleSet.tfNameTop := na
        if not na(candleSet.tfNameBottom)
            label.delete(candleSet.tfNameBottom)
            candleSet.tfNameBottom := na
        if not na(candleSet.tfTimerTop)
            label.delete(candleSet.tfTimerTop)
            candleSet.tfTimerTop := na
        if not na(candleSet.tfTimerBottom)
            label.delete(candleSet.tfTimerBottom)
            candleSet.tfTimerBottom := na
    candleSet

method FindImbalance(CandleSet candleSet) =>
    if barstate.isrealtime or barstate.islast
        if candleSet.imbalances.size() > 0
            for i = candleSet.imbalances.size() - 1 to 0 by 1
                Imbalance del = candleSet.imbalances.get(i)
                box.delete(del.b)
                candleSet.imbalances.pop()
        if candleSet.candles.size() > 3 and settings.fvg_show
            for i = 0 to candleSet.candles.size() - 3 by 1
                candle1 = candleSet.candles.get(i)
                candle2 = candleSet.candles.get(i + 2)
                candle3 = candleSet.candles.get(i + 1)
                if candle1.l > candle2.h and math.min(candle1.o, candle1.c) > math.max(candle2.o, candle2.c)
                    Imbalance imb = Imbalance.new()
                    imb.b := box.new(box.get_left(candle2.body), candle2.h, box.get_right(candle1.body), candle1.l, bgcolor = settings.fvg_color, border_color = color_transparent, xloc = xloc.bar_index)
                    candleSet.imbalances.push(imb)
                if candle1.h < candle2.l and math.max(candle1.o, candle1.c) < math.min(candle2.o, candle2.c)
                    Imbalance imb = Imbalance.new()
                    imb.b := box.new(box.get_right(candle1.body), candle1.h, box.get_left(candle2.body), candle2.l, bgcolor = settings.fvg_color, border_color = color_transparent)
                    candleSet.imbalances.push(imb)
                box temp = box.copy(candle3.body)
                box.delete(candle3.body)
                candle3.body := temp
        if candleSet.candles.size() > 2 and settings.vi_show
            for i = 0 to candleSet.candles.size() - 2 by 1
                candle1 = candleSet.candles.get(i)
                candle2 = candleSet.candles.get(i + 1)
                if candle1.l < candle2.h and math.min(candle1.o, candle1.c) > math.max(candle2.o, candle2.c)
                    Imbalance imb = Imbalance.new()
                    imb.b := box.new(box.get_left(candle2.body), math.min(candle1.o, candle1.c), box.get_right(candle1.body), math.max(candle2.o, candle2.c), bgcolor = settings.vi_color, border_color = color_transparent)
                    candleSet.imbalances.push(imb)
                if candle1.h > candle2.l and math.max(candle1.o, candle1.c) < math.min(candle2.o, candle2.c)
                    Imbalance imb = Imbalance.new()
                    imb.b := box.new(box.get_right(candle1.body), math.min(candle2.o, candle2.c), box.get_left(candle2.body), math.max(candle1.o, candle1.c), bgcolor = settings.vi_color, border_color = color_transparent)
                    candleSet.imbalances.push(imb)
    candleSet

method Monitor(CandleSet candleSet) =>
    HTFBarTime     = time(candleSet.settings.htf, 'America/New_York')
    isNewHTFCandle = ta.change(HTFBarTime) > 0
    if settings.use_custom_daily and candleSet.settings.htf == '1D'
        if settings.custom_daily == 'Midnight'
            isNewHTFCandle := dayofweek(time, 'America/New_York') != dayofweek(time - (time - time[1]), 'America/New_York')
        if settings.custom_daily == '8:30'
            isNewHTFCandle := not na(time(timeframe.period, '0830-0831:123456', 'America/New_York')) and na(time(timeframe.period, '0830-0831:123456', 'America/New_York')[1])
        if settings.custom_daily == '9:30'
            isNewHTFCandle := not na(time(timeframe.period, '0930-0931:123456', 'America/New_York')) and na(time(timeframe.period, '0930-0831:123456', 'America/New_York')[1])
    if isNewHTFCandle
        Candle candle  = Candle.new()
        candle.o       := open
        candle.c       := close
        candle.h       := high
        candle.l       := low
        candle.o_time  := time
        candle.o_idx   := bar_index
        candle.c_idx   := bar_index
        candle.h_idx   := bar_index
        candle.l_idx   := bar_index
        candle.dow     := switch
            candleSet.settings.htf == '1D' =>
                helper.DayofWeek(dayofweek(time_tradingday, 'America/New_York'))
            str.tonumber(candleSet.settings.htf) < 60 =>
                str.format_time(candle.o_time, 'm', 'America/New_York')
            str.tonumber(candleSet.settings.htf) >= 60 =>
                str.format_time(candle.o_time, 'H', 'America/New_York')
            candleSet.settings.htf == '1M' =>
                str.format_time(candle.o_time, 'M', 'America/New_York')
            =>
                ''
        bull        = candle.c > candle.o
        candle.body := box.new(bar_index, math.max(candle.o, candle.c), bar_index + 2, math.min(candle.o, candle.c), bull ? settings.bull_border : settings.bear_border, 1, bgcolor = bull ? settings.bull_body : settings.bear_body)
        candle.wick_up   := line.new(bar_index + 1, candle.h, bar_index, math.max(candle.o, candle.c), color = bull ? settings.bull_wick : settings.bear_wick)
        candle.wick_down := line.new(bar_index + 1, math.min(candle.o, candle.c), bar_index, candle.l, color = bull ? settings.bull_wick : settings.bear_wick)
        candleSet.candles.unshift(candle)
        if candleSet.candles.size() > candleSet.settings.max_display
            Candle delCandle = array.pop(candleSet.candles)
            box.delete(delCandle.body)
            line.delete(delCandle.wick_up)
            line.delete(delCandle.wick_down)
            if not na(delCandle.dow_label)
                delCandle.dow_label.delete()
    candleSet

method Update(CandleSet candleSet, int offset, bool showTrace) =>
    if candleSet.candles.size() > 0
        Candle candle = candleSet.candles.first()
        candle.h_idx := high > candle.h ? bar_index : candle.h_idx
        candle.h     := high > candle.h ? high : candle.h
        candle.l_idx := low  < candle.l ? bar_index : candle.l_idx
        candle.l     := low  < candle.l ? low  : candle.l
        candle.c     := close
        candle.c_idx := bar_index
        bull = candle.c > candle.o
        box.set_top(candle.body,          candle.o)
        box.set_bottom(candle.body,       candle.c)
        box.set_bgcolor(candle.body,      bull ? settings.bull_body   : settings.bear_body)
        box.set_border_color(candle.body, bull ? settings.bull_border : settings.bear_border)
        line.set_color(candle.wick_up,    bull ? settings.bull_wick   : settings.bear_wick)
        line.set_color(candle.wick_down,  bull ? settings.bull_wick   : settings.bear_wick)
        line.set_y1(candle.wick_up,   candle.h)
        line.set_y2(candle.wick_up,   math.max(candle.o, candle.c))
        line.set_y1(candle.wick_down, candle.l)
        line.set_y2(candle.wick_down, math.min(candle.o, candle.c))
        if barstate.isrealtime or barstate.islast
            candleSet.Reorder(offset)
            if settings.trace_show and showTrace
                if bar_index - candle.o_idx < 5000
                    if na(trace.o)
                        trace.o := line.new(candle.o_idx, candle.o, box.get_left(candle.body), candle.o, xloc = xloc.bar_index, color = settings.trace_o_color, style = helper.LineStyle(settings.trace_o_style), width = settings.trace_o_size)
                    else
                        line.set_xy1(trace.o, candle.o_idx, candle.o)
                        line.set_xy2(trace.o, box.get_left(candle.body), candle.o)
                    if settings.label_show
                        if na(trace.o_l)
                            trace.o_l := label.new(box.get_right(candle.body), candle.o, str.tostring(candle.o), textalign = text.align_center, style = label.style_label_left, size = settings.label_size, color = color_transparent, textcolor = settings.label_color)
                        else
                            label.set_xy(trace.o_l,   box.get_right(candle.body), candle.o)
                            label.set_text(trace.o_l, str.tostring(candle.o))
                if bar_index - candle.c_idx < 5000
                    if na(trace.c)
                        trace.c := line.new(candle.c_idx, candle.c, box.get_left(candle.body), candle.c, xloc = xloc.bar_index, color = settings.trace_c_color, style = helper.LineStyle(settings.trace_c_style), width = settings.trace_c_size)
                    else
                        line.set_xy1(trace.c, candle.c_idx, candle.c)
                        line.set_xy2(trace.c, box.get_left(candle.body), candle.c)
                    if settings.label_show
                        if na(trace.c_l)
                            trace.c_l := label.new(box.get_right(candle.body), candle.c, str.tostring(candle.c), textalign = text.align_center, style = label.style_label_left, size = settings.label_size, color = color_transparent, textcolor = settings.label_color)
                        else
                            label.set_xy(trace.c_l,   box.get_right(candle.body), candle.c)
                            label.set_text(trace.c_l, str.tostring(candle.c))
                if bar_index - candle.h_idx < 5000
                    if na(trace.h)
                        trace.h := line.new(candle.h_idx, candle.h, line.get_x1(candle.wick_up), candle.h, xloc = xloc.bar_index, color = settings.trace_h_color, style = helper.LineStyle(settings.trace_h_style), width = settings.trace_h_size)
                    else
                        line.set_xy1(trace.h, candle.h_idx, candle.h)
                        line.set_xy2(trace.h, line.get_x1(candle.wick_up), candle.h)
                    if settings.label_show
                        if na(trace.h_l)
                            trace.h_l := label.new(box.get_right(candle.body), candle.h, str.tostring(candle.h), textalign = text.align_center, style = label.style_label_left, size = settings.label_size, color = color_transparent, textcolor = settings.label_color)
                        else
                            label.set_xy(trace.h_l,   box.get_right(candle.body), candle.h)
                            label.set_text(trace.h_l, str.tostring(candle.h))
                if bar_index - candle.l_idx < 5000
                    if na(trace.l)
                        trace.l := line.new(candle.l_idx, candle.l, line.get_x1(candle.wick_down), candle.l, xloc = xloc.bar_index, color = settings.trace_l_color, style = helper.LineStyle(settings.trace_l_style), width = settings.trace_l_size)
                    else
                        line.set_xy1(trace.l, candle.l_idx, candle.l)
                        line.set_xy2(trace.l, line.get_x1(candle.wick_down), candle.l)
                    if settings.label_show
                        if na(trace.l_l)
                            trace.l_l := label.new(box.get_right(candle.body), candle.l, str.tostring(candle.l), textalign = text.align_center, style = label.style_label_left, size = settings.label_size, color = color_transparent, textcolor = settings.label_color)
                        else
                            label.set_xy(trace.l_l,   box.get_right(candle.body), candle.l)
                            label.set_text(trace.l_l, str.tostring(candle.l))
    candleSet

method Clear(CandleSet candleSet) =>
    if candleSet.candles.size() > 0
        for i = candleSet.candles.size() - 1 to 0 by 1
            Candle c = candleSet.candles.get(i)
            box.delete(c.body)
            line.delete(c.wick_up)
            line.delete(c.wick_down)
            if not na(c.dow_label)
                label.delete(c.dow_label)
            candleSet.candles.pop()
    if candleSet.imbalances.size() > 0
        for i = candleSet.imbalances.size() - 1 to 0 by 1
            Imbalance im = candleSet.imbalances.get(i)
            box.delete(im.b)
            candleSet.imbalances.pop()
    if not na(candleSet.tfNameTop)
        label.delete(candleSet.tfNameTop)
        candleSet.tfNameTop := na
    if not na(candleSet.tfNameBottom)
        label.delete(candleSet.tfNameBottom)
        candleSet.tfNameBottom := na
    if not na(candleSet.tfTimerTop)
        label.delete(candleSet.tfTimerTop)
        candleSet.tfTimerTop := na
    if not na(candleSet.tfTimerBottom)
        label.delete(candleSet.tfTimerBottom)
        candleSet.tfTimerBottom := na
    candleSet

method ClearTrace(Helper helper) =>
    helper.name := 'ClearTrace'
    if not na(trace.o)
        line.delete(trace.o)
        trace.o := na
    if not na(trace.c)
        line.delete(trace.c)
        trace.c := na
    if not na(trace.h)
        line.delete(trace.h)
        trace.h := na
    if not na(trace.l)
        line.delete(trace.l)
        trace.l := na
    if not na(trace.o_l)
        label.delete(trace.o_l)
        trace.o_l := na
    if not na(trace.c_l)
        label.delete(trace.c_l)
        trace.c_l := na
    if not na(trace.h_l)
        label.delete(trace.h_l)
        trace.h_l := na
    if not na(trace.l_l)
        label.delete(trace.l_l)
        trace.l_l := na

// ═══════════════════════════════════════════════════════════════
// MAIN EXECUTION
// ═══════════════════════════════════════════════════════════════

int  cnt     = 0
int  last    = helper.HTFEnabled()
bool drewAny = false
int  offset  = settings.offset

if htf1.settings.show and helper.ValidTimeframe(htf1.settings.htf) and cnt < last
    bool showTrace = false
    if settings.trace_anchor == 'First Timeframe' and cnt == 0
        showTrace := true
    if settings.trace_anchor == 'Last Timeframe' and cnt == last - 1
        showTrace := true
    htf1.UpdateTime()
    htf1.Monitor().Update(offset, showTrace).FindImbalance()
    cnt     := cnt + 1
    drewAny := true
    offset  := offset + (htf1.candles.size() * settings.width + (htf1.candles.size() > 0 ? (htf1.candles.size() - 1) * settings.buffer : 0) + settings.htf_buffer)
else
    htf1.Clear()

if htf2.settings.show and helper.ValidTimeframe(htf2.settings.htf) and cnt < last
    bool showTrace = false
    if settings.trace_anchor == 'First Timeframe' and cnt == 0
        showTrace := true
    if settings.trace_anchor == 'Last Timeframe' and cnt == last - 1
        showTrace := true
    htf2.UpdateTime()
    htf2.Monitor().Update(offset, showTrace).FindImbalance()
    cnt     := cnt + 1
    drewAny := true
    offset  := offset + (htf2.candles.size() * settings.width + (htf2.candles.size() > 0 ? (htf2.candles.size() - 1) * settings.buffer : 0) + settings.htf_buffer)
else
    htf2.Clear()

if htf3.settings.show and helper.ValidTimeframe(htf3.settings.htf) and cnt < last
    bool showTrace = false
    if settings.trace_anchor == 'First Timeframe' and cnt == 0
        showTrace := true
    if settings.trace_anchor == 'Last Timeframe' and cnt == last - 1
        showTrace := true
    htf3.UpdateTime()
    htf3.Monitor().Update(offset, showTrace).FindImbalance()
    cnt     := cnt + 1
    drewAny := true
else
    htf3.Clear()

if not settings.trace_show or not drewAny
    helper.ClearTrace()
