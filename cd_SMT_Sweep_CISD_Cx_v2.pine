//   • T-Sport lines (CISD anchor + SMT trigger + HTF high/low anchor)
//   • Projection Levels from HTF candle (50% CE, 100% Equal, -100% Extension)
//   • Liquidity Sweep Entry signals (3 modes displayed simultaneously)

//@version=6
indicator("cd_SMT_Sweep_CISD_Cx [CienPham v2]", overlay=true,
     max_boxes_count  = 500,
     max_lines_count  = 500,
     max_labels_count = 500)

// ═══════════════════════════════════════════════════════════════
// ORIGINAL INPUTS (unchanged)
// ═══════════════════════════════════════════════════════════════
show_smt_table = input.bool(defval=true,  title="Show SMT table",   group="Show/Hide Tables", inline="1")
show_swe_table = input.bool(defval=true,  title="Show Sweep table",  group="Show/Hide Tables", inline="1")
show_candles   = input.bool(defval=true,  title="Show HTF candles",  group="Show/Hide HTF candles", inline="1a")
show_tfcandles = input.bool(defval=false, title="Show Only alignment HTF candles", group="Show/Hide HTF candles", inline="1a")

show_bucisd    = input.bool(defval=true,  title="Show Bullish CISD levels", group="Show/Hide CISD", inline="2")
show_becisd    = input.bool(defval=true,  title="Show Bearish CISD levels", group="Show/Hide CISD", inline="2")
show_tfcisd    = input.bool(defval=false, title="Show only TF CISD levels", group="Show/Hide CISD", inline="2")

smt_on_chart   = input.bool(defval=true,  title="Show SMTs on chart--",    group="Show/Hide on chart", inline="smt")
style_smt      = input.string(defval=line.style_solid, title="Style:", options=[line.style_solid,line.style_dotted,line.style_dashed], group="Show/Hide on chart", inline="smt")
sweep_on_chart = input.bool(defval=true,  title="Show Sweeps on chart--",  group="Show/Hide on chart", inline="swe")
style_swp      = input.string(defval=line.style_dotted, title="Style:", options=[line.style_solid,line.style_dotted,line.style_dashed], group="Show/Hide on chart", inline="swe")

showhtf      = input.bool(defval=true,    title="Show HTF",          group="Show/Hide HTF separetes", inline="htf1")
htf_opt      = input.string(defval="Boxes", title="Boxes/Lines",     options=["Boxes","Lines"],        group="Show/Hide HTF separetes", inline="htf1")
width_box    = input.int(defval=1,        title="Border Width :",    group="Show/Hide HTF separetes", inline="htf2")
style_box    = input.string(defval=line.style_dotted, title="Style:", options=[line.style_solid,line.style_dotted,line.style_dashed], group="Show/Hide HTF separetes", inline="htf2")
line_clr     = input.color(defval=color.navy, title="Color :", group="Show/Hide HTF separetes", inline="htf2")

single       = input.bool(defval=true,  title="Single Candle SMT Alerts", group="Alerts", inline="al2")
alert1_on    = input.bool(defval=false, title="Activate Alert (SMT + Sweep)", group="Alerts", tooltip="for selected HTFs (SMT + Sweep)")
alert2_on    = input.bool(defval=false, title="Activate Alert (Sweep + Sweep)", group="Alerts", tooltip="Both asset sweep")
