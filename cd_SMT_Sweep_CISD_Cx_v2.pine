bealert      = input.bool(defval=true,  title="Bearish Alerts", group="Alerts", inline="al")

g1 = "  [-------- CISD TF  -----------------  HTF for SMT/Sweep/Candles ------]"
ctfok1 = input.bool(defval=true,  title="", group=g1, inline="1")
