ctfok4 = input.bool(defval=true,  title="", group=g1, inline="4")
ctfok5 = input.bool(defval=true,  title="", group=g1, inline="5")
ctfok6 = input.bool(defval=true,  title="", group=g1, inline="6")
ctfok7 = input.bool(defval=true,  title="", group=g1, inline="7")
ctfok8 = input.bool(defval=true,  title="", group=g1, inline="8")
ctfok9 = input.bool(defval=true,  title="", group=g1, inline="9")

ctf1 = input.timeframe(defval="1W",  title="cisd tf:", group=g1, inline="1")
ctf2 = input.timeframe(defval="1D",  title="cisd tf:", group=g1, inline="2")
