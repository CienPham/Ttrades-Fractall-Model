s1  = input.symbol(defval="PEPPERSTONE:NAS100", title="1 : ", group="Correlated pairs", inline="s1")
s2  = input.symbol(defval="PEPPERSTONE:US500",  title=" & ",  group="Correlated pairs", inline="s1")
s3  = input.symbol(defval="PEPPERSTONE:EURUSD", title="2 : ", group="Correlated pairs", inline="s2")
