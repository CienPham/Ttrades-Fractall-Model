tf3 = input.timeframe(defval="1W",  title="TF3:", group=g1, inline="3")
tf4 = input.timeframe(defval="1D",  title="TF4:", group=g1, inline="4")
tf5 = input.timeframe(defval="720", title="TF5:", group=g1, inline="5")
