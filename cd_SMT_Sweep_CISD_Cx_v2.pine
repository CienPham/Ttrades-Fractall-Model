tf9 = input.timeframe(defval="15",  title="TF9:", group=g1, inline="9")

ok1 = input.bool(defval=true, title="", group="Correlated pairs", inline="s1")
ok2 = input.bool(defval=true, title="", group="Correlated pairs", inline="s2")
ok3 = input.bool(defval=true, title="", group="Correlated pairs", inline="s3")
