s8  = input.symbol(defval="CBOT_MINI:YM1!",     title=" & ",  group="Correlated pairs", inline="s4")

bull_clr     = input.color(color.new(color.teal,0),   title="Bullish",              inline="clr1", group="Candle Colors")
bear_clr     = input.color(color.new(color.red,0),    title="Bearish",              inline="clr1", group="Candle Colors")
eq_clr       = input.color(color.new(color.black,50), title="Range",                inline="clr1", group="Candle Colors")
can_br_color = input.color(defval=color.black,        title="Candles Border Color", inline="clr1", group="Candle Colors")
smt_clr      = input.color(color.new(color.purple,0), title="SMT",   inline="clr2", group="SMT & Sweep Colors")
swp_clr      = input.color(color.new(color.blue,0),   title="Sweep", inline="clr2", group="SMT & Sweep Colors")
bucsd_clr    = input.color(color.new(color.teal,0),   title="Bullish CISD ", inline="clr3", group="CISD Colors")
becsd_clr    = input.color(color.new(color.red,0),    title="Bearish CISD ", inline="clr3", group="CISD Colors")
csd_style    = input.string(defval=line.style_dashed, title="Line style:", options=[line.style_solid,line.style_dashed,line.style_dotted], inline="clr3", group="CISD Colors")

i_font     = input.string("tiny", "Text size", options=["tiny","small","normal","large","huge"], group="Table")
i_pos      = input.string(position.middle_right, "Table Position", inline="1",
     options=[position.middle_right,position.top_right,position.bottom_right,position.bottom_center,position.bottom_left], group="Table")
i_main_clr  = color.blue
i_title_clr = color.red
i_bgcolor   = color.teal
i_textcolor = color.white

// ═══════════════════════════════════════════════════════════════
// NEW INPUTS — T-Sport / Projection / Liquidity Sweep Entry
// ═══════════════════════════════════════════════════════════════
string g_tsport = "T-Sport Settings"
string g_proj   = "Projection Levels"
string g_entry  = "Liquidity Sweep Entry Signals"

// T-Sport
show_tsport      = input.bool(true,  "Show T-Sport lines",          group=g_tsport)
tsport_cisd      = input.bool(true,  "T-Sport from CISD level",     group=g_tsport, inline="ts1")
tsport_smt       = input.bool(true,  "Activate on SMT signal",      group=g_tsport, inline="ts1")
tsport_htf       = input.bool(true,  "T-Sport from HTF High/Low",   group=g_tsport, inline="ts2")
tsport_clr_bull  = input.color(color.new(#00BCD4, 20), "Bull T-Sport", group=g_tsport, inline="ts3")
tsport_clr_bear  = input.color(color.new(#FF5722, 20), "Bear T-Sport", group=g_tsport, inline="ts3")
tsport_width     = input.int(1, "Width", minval=1, maxval=4,         group=g_tsport, inline="ts4")
tsport_style     = input.string(line.style_dashed, "Style",
     options=[line.style_solid,line.style_dashed,line.style_dotted], group=g_tsport, inline="ts4")
tsport_extend    = input.int(20, "Extend bars →", minval=5, maxval=200, group=g_tsport)

// Projection Levels
show_proj        = input.bool(true,  "Show Projection Levels",       group=g_proj)
proj_tf          = input.timeframe("60", "HTF for projection",        group=g_proj, inline="pj1")
proj_50          = input.bool(true,  "50% CE level",                 group=g_proj, inline="pj2")
proj_100         = input.bool(true,  "100% Equal Move",              group=g_proj, inline="pj2")
proj_neg100      = input.bool(true,  "-100% Extension",              group=g_proj, inline="pj2")
proj_clr_50      = input.color(color.new(#FFD700, 60), "50% CE",     group=g_proj, inline="pj3")
proj_clr_100     = input.color(color.new(#4CAF50, 60), "100%",       group=g_proj, inline="pj3")
proj_clr_neg100  = input.color(color.new(#F44336, 60), "-100%",      group=g_proj, inline="pj3")
proj_extend      = input.int(40, "Extend bars →", minval=10, maxval=500, group=g_proj)

// Liquidity Sweep Entry
show_entry       = input.bool(true,  "Show Entry Signals",           group=g_entry)
entry_mode_full  = input.bool(true,  "Full Confluence (Sweep+CISD+SMT)", group=g_entry, inline="em")
entry_mode_sw_cs = input.bool(true,  "Sweep + CISD only",            group=g_entry, inline="em")
entry_mode_sw_sm = input.bool(true,  "Sweep + SMT only",             group=g_entry, inline="em")
entry_bull_clr   = input.color(color.new(#00E676, 0), "Bull Entry",  group=g_entry, inline="ec")
entry_bear_clr   = input.color(color.new(#FF1744, 0), "Bear Entry",  group=g_entry, inline="ec")
entry_label_size = input.string(size.small, "Label size",
     options=[size.tiny,size.small,size.normal,size.large], group=g_entry)
show_entry_table = input.bool(true, "Show Entry Table", group=g_entry)

// ═══════════════════════════════════════════════════════════════
// ORIGINAL GLOBALS
// ═══════════════════════════════════════════════════════════════
sym      = syminfo.tickerid
tf       = timeframe.period
var tablo2 = table.new(position=i_pos, columns=10, rows=30,
     frame_color=i_textcolor, frame_width=2,
     border_color=i_textcolor, border_width=1)
assets   = array.from(str.contains(sym,s1),str.contains(sym,s2),
     str.contains(sym,s3),str.contains(sym,s4),
     str.contains(sym,s5),str.contains(sym,s6),
     str.contains(sym,s7),str.contains(sym,s8))
asset_ok = array.some(assets)

add_to_array(arr, value) =>
    array.unshift(arr, value)
    if array.size(arr) > 100
        array.pop(arr)

f_live_sym(_xc0,_xo0,_xh0,_xl0,_xt0,xtf) =>
    var _c1=0.0, var _o1=0.0, var _h1=0.0, var _l1=0.0, var _t1=0
    var _c2=0.0, var _o2=0.0, var _h2=0.0, var _l2=0.0, var _t2=0
    var _o0=0.0, var _h0=0.0, var _l0=0.0, var _t0=0, var _c0=0.0
    if timeframe.change(xtf)
        _t0:=_xt0; _o0:=_xo0; _h0:=_xh0; _l0:=_xl0
    if _xh0>=_h0 => _h0:=_xh0
    if _xl0<=_l0 => _l0:=_xl0
    _c0:=_xc0
    if timeframe.change(xtf)
        _c1:=_c0[1]; _o1:=_o0[1]; _h1:=_h0[1]; _l1:=_l0[1]; _t1:=_t0[1]
        _c2:=_c1[1]; _o2:=_o1[1]; _h2:=_h1[1]; _l2:=_l1[1]; _t2:=_t1[1]
    [_h2,_l2,_c2,_o2,_t2,_h1,_l1,_c1,_o1,_t1,_h0,_l0,_c0,_o0,_t0]

f_text(string _tf) =>
    _text = str.tonumber(_tf)<59 ? _tf+'m' :
     str.tonumber(_tf)>59 ? 'h'+str.tostring(math.floor(str.tonumber(_tf)/60)) : _tf
    _text:= _tf=="1D" ? "D" : _tf=="1W" ? "W" : _tf=="1M" ? "M" : _text

tf_ok(_htf) =>
    _ok = timeframe.in_seconds(_htf)>=timeframe.in_seconds(timeframe.period)
    _ok:= _htf=="360" and (tf=="240" or tf=="300") ? false : _ok

f_live_mini_time(_htf) =>
    var _h0=high, var _l0=low
    var _h0t=time, var _l0t=time
    var _h1t=time, var _l1t=time
    var _h2t=time, var _l2t=time
    if timeframe.change(_htf)
        _h0:=high; _l0:=low
    if high>=_h0 => _h0:=high;  _h0t:=time
    if low<=_l0  => _l0:=low;   _l0t:=time
    if timeframe.change(_htf)
        _h1t:=_h0t[1]; _l1t:=_l0t[1]
        _h2t:=_h1t[1]; _l2t:=_l1t[1]
    [_h2t,_l2t,_h1t,_l1t,_h0t,_l0t]

f_smt(_tf,_tfok,_ctf) =>
    csym=sym
    csym:= str.contains(sym,s1)and ok1 ? s2 : str.contains(sym,s2)and ok2 ? s1 : csym
    csym:= str.contains(sym,s3)and ok2 ? s4 : str.contains(sym,s4)and ok2 ? s3 : csym
    csym:= str.contains(sym,s5)and ok3 ? s6 : str.contains(sym,s6)and ok3 ? s5 : csym
    csym:= str.contains(sym,s7)and ok4 ? s8 : str.contains(sym,s8)and ok4 ? s7 : csym
    csym:= syminfo.type=="futures" ? ticker.modify(csym,session=syminfo.session,backadjustment=backadjustment.on) : csym
    par_ok = csym!=sym

    [cc,co,ch,cl,ct]=request.security(csym,tf,[close,open,high,low,time],
     lookahead=barmerge.lookahead_on,gaps=barmerge.gaps_off,ignore_invalid_symbol=true)

    [xh2,xl2,xc2,xo2,xt2,xh1,xl1,xc1,xo1,xt1,xh0,xl0,xc0,xo0,xt0]=f_live_sym(close,open,high,low,time,_tf)
    [ch2,cl2,cc2,co2,ct2,ch1,cl1,cc1,co1,ct1,ch0,cl0,cc0,co0,ct0]=f_live_sym(cc,co,ch,cl,ct,_tf)

    bear_smt1=(( xh0> xh1 and ch0<=ch1) or ( xh0<=xh1 and ch0> ch1)) and par_ok and tf_ok(_tf)
    bull_smt1=(( xl0< xl1 and cl0>=cl1) or ( xl0>=xl1 and cl0< cl1)) and par_ok and tf_ok(_tf)
    bear_smt2=(( xh1<xh2 and xh0>xh2 and ch1<ch0 and ch2>ch0) or (xh1<xh0 and xh2>xh0 and ch1<ch2 and ch0>ch2)) and par_ok and tf_ok(_tf)
    bull_smt2=(( xl1>xl2 and xl0<xl2 and cl1>cl0 and cl2<cl0) or (xl1>xl0 and xl2<xl0 and cl1>cl2 and cl0<cl2)) and par_ok and tf_ok(_tf)
    bull_smt = bull_smt1 or bull_smt2
    bear_smt = bear_smt1 or bear_smt2
    bull_num  = bull_smt2 ? 2 : bull_smt1 ? 1 : 0
    bear_num  = bear_smt2 ? 2 : bear_smt1 ? 1 : 0

    xh_sweep = xh0>xh1 and xc0<xh1 and tf_ok(_tf)
    xl_sweep = xl0<xl1 and xc0>xl1 and tf_ok(_tf)
    ch_sweep = ch0>ch1 and cc0<ch1 and tf_ok(_tf)
    cl_sweep = cl0<cl1 and cc0>cl1 and tf_ok(_tf)

    if par_ok and show_smt_table and show_swe_table
        table.merge_cells(tablo2,0,10,6,10)
        table.cell(tablo2,0,10,text="Corele asset : "+str.tostring(csym),text_color=i_textcolor,bgcolor=i_main_clr,text_size=i_font)
    if par_ok and show_smt_table and not show_swe_table
        table.merge_cells(tablo2,0,10,2,10)
        table.cell(tablo2,0,10,text="Corele : "+str.tostring(csym),text_color=i_textcolor,bgcolor=i_main_clr,text_size=i_font)

    var bullalerttrigger1=false, var bearalerttrigger1=false
    var bullalerttrigger2=false, var bearalerttrigger2=false
    var busingalerttrigger2=false, var besingalerttrigger2=false
    if timeframe.change(_tf)
        bullalerttrigger1:=false; bearalerttrigger1:=false
        bullalerttrigger2:=false; bearalerttrigger2:=false
        busingalerttrigger2:=false; besingalerttrigger2:=false

    bullalert=par_ok and _tfok and bull_smt and (xl_sweep or cl_sweep) and alert1_on and bualert
    bearalert=par_ok and _tfok and bear_smt and (xh_sweep or ch_sweep) and alert1_on and bealert
    if bullalert and bullalerttrigger1==false
        alert(str.tostring(syminfo.ticker(sym))+" "+f_text(_tf)+" Bullish Alert SMT + Sweep",alert.freq_once_per_bar)
        bullalerttrigger1:=true
    if bearalert and bearalerttrigger1==false
        alert(str.tostring(syminfo.ticker(sym))+" "+f_text(_tf)+" Bearish Alert SMT + Sweep",alert.freq_once_per_bar)
        bearalerttrigger1:=true

    bullalert2=par_ok and _tfok and xl_sweep and cl_sweep and alert2_on and bualert
    bearalert2=par_ok and _tfok and xh_sweep and ch_sweep and alert2_on and bealert
    if bullalert2 and bullalerttrigger2==false
        alert(str.tostring(syminfo.ticker(sym))+" "+f_text(_tf)+" Bullish Alert Sweep + Sweep",alert.freq_once_per_bar)
        bullalerttrigger2:=true
    if bearalert2 and bearalerttrigger2==false
        alert(str.tostring(syminfo.ticker(sym))+" "+f_text(_tf)+" Bearish Alert Sweep + Sweep",alert.freq_once_per_bar)
        bearalerttrigger2:=true

    bullalert3=par_ok and _tfok and bull_smt and bualert
    if bullalert3 and busingalerttrigger2==false
        alert(str.tostring(syminfo.ticker(sym))+" "+f_text(_tf)+" Bullish SMT",alert.freq_once_per_bar)
        busingalerttrigger2:=true
    bearalert3=par_ok and _tfok and bear_smt and bealert
    if bearalert3 and besingalerttrigger2==false
        alert(str.tostring(syminfo.ticker(sym))+" "+f_text(_tf)+" Bearish SMT",alert.freq_once_per_bar)
        besingalerttrigger2:=true

    var smtbeh=line.new(na,na,na,na), var smtbul=line.new(na,na,na,na)
    var swebeh=line.new(na,na,na,na), var swebul=line.new(na,na,na,na)
    line.delete(smtbeh); line.delete(smtbul)
    line.delete(swebeh); line.delete(swebul)
    [h2t,l2t,h1t,l1t,h0t,l0t]=f_live_mini_time(_tf)
    if par_ok and tf_ok(_tf) and smt_on_chart and (bull_smt or bear_smt) and tf==_ctf and _tfok
        if bear_smt and not (bear_num==0)
            x1=bear_num==1 ? h1t : bear_num==2 ? h2t : 0
            y1=bear_num==1 ? xh1 : bear_num==2 ? xh2 : 0
            smtbeh:=line.new(x1=x1,y1=y1,x2=h0t,y2=xh0,xloc=xloc.bar_time,color=smt_clr,width=2,style=style_smt)
        if bull_smt and not (bull_num==0)
            x1=bull_num==1 ? l1t : bull_num==2 ? l2t : 0
            y1=bull_num==1 ? xl1 : bull_num==2 ? xl2 : 0
            smtbul:=line.new(x1=x1,y1=y1,x2=l0t,y2=xl0,xloc=xloc.bar_time,color=smt_clr,width=2,style=style_smt)
    if tf_ok(_tf) and sweep_on_chart and (xh_sweep or xl_sweep) and tf==_ctf and _tfok
        if xh_sweep
            swebeh:=line.new(x1=h1t,y1=xh1,x2=h0t,y2=xh1,xloc=xloc.bar_time,color=swp_clr,width=2,style=style_swp)
        if xl_sweep
            swebul:=line.new(x1=l1t,y1=xl1,x2=l0t,y2=xl1,xloc=xloc.bar_time,color=swp_clr,width=2,style=style_swp)

    [bull_smt,bear_smt,bull_num,bear_num,xh_sweep,xl_sweep,ch_sweep,cl_sweep]

f_smt_txt(bool _alarm) =>
    _alarm ? "✓" : "𐄂"

f_swp_txt(bool _alarm1,bool _alarm2) =>
    _textt1=_alarm1 and _alarm2 ? "✓ ✓" : _alarm1 and not _alarm2 ? "✓ 𐄂" : not _alarm1 and _alarm2 ? "𐄂 ✓" : "𐄂 𐄂"
    _textt=asset_ok ? _textt1 : _alarm1 ? " ✓ " : " 𐄂 "
    _textt

Getcolor_candle(_o,_c) =>
    _c>_o ? bull_clr : _o>_c ? bear_clr : eq_clr

f_plot_candle(start,_tf,smth,smtl,swph,swpl,bull_num,bear_num) =>
    [_h2,_l2,_c2,_o2,_t2,_h1,_l1,_c1,_o1,_t1,_h,_l,_c,_o,_t0]=f_live_sym(close,open,high,low,time,_tf)
    txt=f_text(_tf)
    dxx=15; q=1; m=3; n=2
    bl0=box.new(left=bar_index+start+dxx+0+m*3,top=_c,right=bar_index+start+dxx+2+m*3,bottom=_o,bgcolor=Getcolor_candle(_o,_c),border_color=can_br_color,text=txt,text_size=i_font,text_valign=text.align_center,text_halign=text.align_center,text_color=color.white)
    wup=box.new(left=bar_index+start+dxx+1+m*3,top=_h,right=bar_index+start+dxx+1+m*3,bottom=math.max(_o,_c),border_color=can_br_color,border_width=1)
    wdw=box.new(left=bar_index+start+dxx+1+m*3,top=_l,right=bar_index+start+dxx+1+m*3,bottom=math.min(_o,_c),border_color=can_br_color,border_width=1)
    box.delete(bl0[1]); box.delete(wup[1]); box.delete(wdw[1])
    bl1=box.new(left=bar_index+start+dxx+0+n*3,top=_c1,right=bar_index+start+dxx+2+n*3,bottom=_o1,bgcolor=Getcolor_candle(_o1,_c1),border_color=can_br_color,text=txt,text_size=i_font,text_valign=text.align_center,text_halign=text.align_center,text_color=color.white)
    wup1=box.new(left=bar_index+start+dxx+1+n*3,top=_h1,right=bar_index+start+dxx+1+n*3,bottom=math.max(_o1,_c1),border_color=can_br_color,border_width=1)
    wdw1=box.new(left=bar_index+start+dxx+1+n*3,top=_l1,right=bar_index+start+dxx+1+n*3,bottom=math.min(_o1,_c1),border_color=can_br_color,border_width=1)
    box.delete(bl1[1]); box.delete(wup1[1]); box.delete(wdw1[1])
    bl2=box.new(left=bar_index+start+dxx+0+q*3,top=_c2,right=bar_index+start+dxx+2+q*3,bottom=_o2,bgcolor=Getcolor_candle(_o2,_c2),border_color=can_br_color,text=txt,text_size=i_font,text_valign=text.align_center,text_halign=text.align_center,text_color=color.white)
    wup2=box.new(left=bar_index+start+dxx+1+q*3,top=_h2,right=bar_index+start+dxx+1+q*3,bottom=math.max(_o2,_c2),border_color=can_br_color,border_width=1)
    wdw2=box.new(left=bar_index+start+dxx+1+q*3,top=_l2,right=bar_index+start+dxx+1+q*3,bottom=math.min(_o2,_c2),border_color=can_br_color,border_width=1)
    box.delete(bl2[1]); box.delete(wup2[1]); box.delete(wdw2[1])

    var ln1=line.new(na,na,na,na), var ln2=line.new(na,na,na,na)
    var ln3=line.new(na,na,na,na), var ln4=line.new(na,na,na,na)
    var ln5=line.new(na,na,na,na), var ln6=line.new(na,na,na,na)
    line.delete(ln1); line.delete(ln2); line.delete(ln3)
    line.delete(ln4); line.delete(ln5); line.delete(ln6)
    if smth and asset_ok
        qn=bear_num==2 ? q : bear_num==1 ? n : 0
        qy=bear_num==2 ? _h2 : bear_num==1 ? _h1 : 0
        ln1:=line.new(x1=bar_index+start+dxx+1+qn*3,y1=qy,x2=bar_index+start+dxx+1+m*3,y2=_h,color=smt_clr)
    if smtl and asset_ok
        nq=bull_num==2 ? q : bull_num==1 ? n : 0
        ny=bull_num==2 ? _l2 : bull_num==1 ? _l1 : 0
        ln2:=line.new(x1=bar_index+start+dxx+1+nq*3,y1=ny,x2=bar_index+start+dxx+1+m*3,y2=_l,color=smt_clr)
    if swph
        ln3:=line.new(x1=bar_index+start+dxx+1+n*3,y1=_h1,x2=bar_index+start+dxx+1+m*3,y2=_h1,color=swp_clr,style=line.style_dotted,width=2)
    if swpl
        ln4:=line.new(x1=bar_index+start+dxx+1+n*3,y1=_l1,x2=bar_index+start+dxx+1+m*3,y2=_l1,color=swp_clr,style=line.style_dotted,width=2)
    if _h1>_h2 and _c1<=_h2
        ln5:=line.new(x1=bar_index+start+dxx+1+q*3,y1=_h2,x2=bar_index+start+dxx+1+n*3,y2=_h2,color=swp_clr,style=line.style_dotted,width=2)
    if _l1<_l2 and _c1>=_l2
        ln6:=line.new(x1=bar_index+start+dxx+1+q*3,y1=_l2,x2=bar_index+start+dxx+1+n*3,y2=_l2,color=swp_clr,style=line.style_dotted,width=2)

arrtfok=array.from(
     tfok9 and tf_ok(tf9) and (show_tfcandles ? tf==ctf9 : true),
     tfok8 and tf_ok(tf8) and (show_tfcandles ? tf==ctf8 : true),
     tfok7 and tf_ok(tf7) and (show_tfcandles ? tf==ctf7 : true),
     tfok6 and tf_ok(tf6) and (show_tfcandles ? tf==ctf6 : true),
     tfok5 and tf_ok(tf5) and (show_tfcandles ? tf==ctf5 : true),
     tfok4 and tf_ok(tf4) and (show_tfcandles ? tf==ctf4 : true),
     tfok3 and tf_ok(tf3) and (show_tfcandles ? tf==ctf3 : true),
     tfok2 and tf_ok(tf2) and (show_tfcandles ? tf==ctf2 : true),
     tfok1 and tf_ok(tf1) and (show_tfcandles ? tf==ctf1 : true))
arrstart=array.from(0,0,0,0,0,0,0,0,0)

f_start() =>
    for i=0 to 8
        array.set(arrstart,i,0)
    j=0
    for i=0 to 8
        if array.get(arrtfok,i)==true
            array.set(arrstart,i,j*10)
            j:=j+1

f_look_tf(_tf) =>
    dtf=_tf=="3M" ? f_text("1W") : _tf=="1M" ? f_text("1D") : _tf=="1W" ? f_text("240") :
     _tf=="1D" ? f_text("60") : _tf=="720" ? f_text("30") : _tf=="240" ? f_text("15") :
     _tf=="60" ? f_text("5") : _tf=="30" ? f_text("3") : _tf=="15" ? f_text("1") : " ? "

f_find_htf() =>
    _tf=tf
    dtf=_tf=="1" ? "15" : _tf=="2" ? "60" : _tf=="3" ? "30" : _tf=="5" ? "60" :
     _tf=="15" ? "240" : _tf=="30" ? "720" : _tf=="60" ? "1D" : _tf=="240" ? "1W" :
     _tf=="1D" ? "1M" : _tf=="1W" ? "3M" : tf
    dtf

// ═══════════════════════════════════════════════════════════════
// ORIGINAL HTF BOX
// ═══════════════════════════════════════════════════════════════
hhtf=[h2,l2,c2,o2,t2,h1,l1,c1,o1,t1,h,l,c,o,t0]=f_live_sym(close,open,high,low,time,f_find_htf())
if tf_ok(f_find_htf()) and time==t0 and timeframe.period!=f_find_htf() and showhtf and htf_opt=="Boxes"
    htf_box_color=c1>o1 ? bull_clr : c1<o1 ? bear_clr : eq_clr
    box.new(left=t1,top=h1,right=t0,bottom=l1,xloc=xloc.bar_time,border_width=1,border_style=style_box,bgcolor=color.rgb(255,255,255,100),border_color=htf_box_color,text="",text_color=htf_box_color,text_size=size.tiny,text_halign=text.align_right,text_valign=text.align_center)
if tf_ok(f_find_htf()) and timeframe.period!=f_find_htf() and showhtf and htf_opt=="Boxes"
    htf_box_color=c>o ? bull_clr : c<o ? bear_clr : eq_clr
    boxhtf=box.new(left=t0,top=high>h ? high : h,right=time+1,bottom=low<l ? low : l,xloc=xloc.bar_time,border_width=width_box,border_style=style_box,bgcolor=color.rgb(255,255,255,100),border_color=htf_box_color,text=f_text(f_find_htf()),text_color=htf_box_color,text_size=size.tiny,text_halign=text.align_left,text_valign=text.align_top)
    box.delete(boxhtf[1])
if tf_ok(f_find_htf()) and timeframe.period!=f_find_htf() and showhtf and htf_opt=="Lines" and t0==time
    dt=timeframe.in_seconds(f_find_htf())*1000
    line.new(x1=t0+dt,y1=o,x2=t0+dt,y2=o+syminfo.mintick,xloc=xloc.bar_time,extend=extend.both,color=line_clr,style=style_box)

// ═══════════════════════════════════════════════════════════════
// ORIGINAL SMT CALLS
// ═══════════════════════════════════════════════════════════════
[tf1_bull_smt,tf1_bear_smt,tf1_bull_num,tf1_bear_num,tf1_xh_sweep,tf1_xl_sweep,tf1_ch_sweep,tf1_cl_sweep]=f_smt(tf1,tfok1,ctf1)
[tf2_bull_smt,tf2_bear_smt,tf2_bull_num,tf2_bear_num,tf2_xh_sweep,tf2_xl_sweep,tf2_ch_sweep,tf2_cl_sweep]=f_smt(tf2,tfok2,ctf2)
[tf3_bull_smt,tf3_bear_smt,tf3_bull_num,tf3_bear_num,tf3_xh_sweep,tf3_xl_sweep,tf3_ch_sweep,tf3_cl_sweep]=f_smt(tf3,tfok3,ctf3)
[tf4_bull_smt,tf4_bear_smt,tf4_bull_num,tf4_bear_num,tf4_xh_sweep,tf4_xl_sweep,tf4_ch_sweep,tf4_cl_sweep]=f_smt(tf4,tfok4,ctf4)
[tf5_bull_smt,tf5_bear_smt,tf5_bull_num,tf5_bear_num,tf5_xh_sweep,tf5_xl_sweep,tf5_ch_sweep,tf5_cl_sweep]=f_smt(tf5,tfok5,ctf5)
[tf6_bull_smt,tf6_bear_smt,tf6_bull_num,tf6_bear_num,tf6_xh_sweep,tf6_xl_sweep,tf6_ch_sweep,tf6_cl_sweep]=f_smt(tf6,tfok6,ctf6)
[tf7_bull_smt,tf7_bear_smt,tf7_bull_num,tf7_bear_num,tf7_xh_sweep,tf7_xl_sweep,tf7_ch_sweep,tf7_cl_sweep]=f_smt(tf7,tfok7,ctf7)
[tf8_bull_smt,tf8_bear_smt,tf8_bull_num,tf8_bear_num,tf8_xh_sweep,tf8_xl_sweep,tf8_ch_sweep,tf8_cl_sweep]=f_smt(tf8,tfok8,ctf8)
[tf9_bull_smt,tf9_bear_smt,tf9_bull_num,tf9_bear_num,tf9_xh_sweep,tf9_xl_sweep,tf9_ch_sweep,tf9_cl_sweep]=f_smt(tf9,tfok9,ctf9)

// ── Aggregate SMT/Sweep state across all active TFs ────────────
any_bull_smt = (tfok1 and tf1_bull_smt) or (tfok2 and tf2_bull_smt) or (tfok3 and tf3_bull_smt) or
               (tfok4 and tf4_bull_smt) or (tfok5 and tf5_bull_smt) or (tfok6 and tf6_bull_smt) or
               (tfok7 and tf7_bull_smt) or (tfok8 and tf8_bull_smt) or (tfok9 and tf9_bull_smt)
any_bear_smt = (tfok1 and tf1_bear_smt) or (tfok2 and tf2_bear_smt) or (tfok3 and tf3_bear_smt) or
               (tfok4 and tf4_bear_smt) or (tfok5 and tf5_bear_smt) or (tfok6 and tf6_bear_smt) or
               (tfok7 and tf7_bear_smt) or (tfok8 and tf8_bear_smt) or (tfok9 and tf9_bear_smt)
any_xl_sweep = (tfok4 and tf4_xl_sweep) or (tfok6 and tf6_xl_sweep) or (tfok7 and tf7_xl_sweep) or
               (tfok8 and tf8_xl_sweep) or (tfok9 and tf9_xl_sweep)
any_xh_sweep = (tfok4 and tf4_xh_sweep) or (tfok6 and tf6_xh_sweep) or (tfok7 and tf7_xh_sweep) or
               (tfok8 and tf8_xh_sweep) or (tfok9 and tf9_xh_sweep)

// ═══════════════════════════════════════════════════════════════
// NEW — PROJECTION LEVELS from HTF candle
// Anchor: last confirmed HTF candle (o1/c1/h1/l1)
// Levels: 50% CE, 100% Equal Move, -100% Extension
// Direction determined by HTF candle bias
// ═══════════════════════════════════════════════════════════════

[ph2,pl2,pc2,po2,pt2,ph1,pl1,pc1,po1,pt1,ph0,pl0,pc0,po0,pt0] =
     f_live_sym(close,open,high,low,time,proj_tf)

// HTF candle body metrics
float proj_body_h   = math.max(po1, pc1)   // top of body
float proj_body_l   = math.min(po1, pc1)   // bottom of body
float proj_body_sz  = proj_body_h - proj_body_l
bool  proj_bull_htf = pc1 >= po1
// Swing from wick to wick (full range of last confirmed candle)
float proj_full_h   = ph1
float proj_full_l   = pl1
float proj_full_sz  = proj_full_h - proj_full_l

// Projection from close of HTF candle outward
// Bull candle: project upward from close
// Bear candle: project downward from close
float proj_anchor   = pc1   // start from last HTF close

float level_50      = proj_bull_htf ? proj_anchor + proj_body_sz * 0.5
                                    : proj_anchor - proj_body_sz * 0.5
float level_100     = proj_bull_htf ? proj_anchor + proj_body_sz
                                    : proj_anchor - proj_body_sz
float level_neg100  = proj_bull_htf ? proj_anchor - proj_body_sz
                                    : proj_anchor + proj_body_sz

var line ln_proj_50     = na
var line ln_proj_100    = na
var line ln_proj_neg100 = na
var label lbl_proj_50   = na
var label lbl_proj_100  = na
var label lbl_proj_neg100 = na

if show_proj and tf_ok(proj_tf) and (barstate.islast or barstate.isrealtime)
    int x1_proj = bar_index
    int x2_proj = bar_index + proj_extend

    if proj_50
        line.delete(ln_proj_50)
        label.delete(lbl_proj_50)
        ln_proj_50    := line.new(x1_proj, level_50, x2_proj, level_50,
             xloc=xloc.bar_index, color=proj_clr_50, style=line.style_dashed, width=1)
        lbl_proj_50   := label.new(x2_proj, level_50,
             "50% CE  " + str.tostring(math.round(level_50, 2)),
             xloc=xloc.bar_index, color=color.new(proj_clr_50,70),
             textcolor=proj_clr_50, style=label.style_label_left, size=size.tiny)

    if proj_100
        line.delete(ln_proj_100)
        label.delete(lbl_proj_100)
        ln_proj_100   := line.new(x1_proj, level_100, x2_proj, level_100,
             xloc=xloc.bar_index, color=proj_clr_100, style=line.style_dashed, width=1)
        lbl_proj_100  := label.new(x2_proj, level_100,
             "100%  " + str.tostring(math.round(level_100, 2)),
             xloc=xloc.bar_index, color=color.new(proj_clr_100,70),
             textcolor=proj_clr_100, style=label.style_label_left, size=size.tiny)

    if proj_neg100
        line.delete(ln_proj_neg100)
        label.delete(lbl_proj_neg100)
        ln_proj_neg100  := line.new(x1_proj, level_neg100, x2_proj, level_neg100,
             xloc=xloc.bar_index, color=proj_clr_neg100, style=line.style_dashed, width=1)
        lbl_proj_neg100 := label.new(x2_proj, level_neg100,
             "-100%  " + str.tostring(math.round(level_neg100, 2)),
             xloc=xloc.bar_index, color=color.new(proj_clr_neg100,70),
             textcolor=proj_clr_neg100, style=label.style_label_left, size=size.tiny)

// ═══════════════════════════════════════════════════════════════
// ORIGINAL CISD METHODS
// ═══════════════════════════════════════════════════════════════
f_live_mini(_htf) =>
    var _o0=open, var _h0=high, var _l0=low, var _t0=time, var _c0=close
    var _h0bar=time, var _l0bar=time
    var _h1=high, var _l1=low, var _t1=time, var _c1=close, var _o1=open
    var _h1bar=time, var _l1bar=time
    if timeframe.change(_htf)
        _t0:=time; _o0:=open; _h0:=high; _l0:=low
    if high>=_h0 => _h0:=high; _h0bar:=time
    if low<=_l0  => _l0:=low;  _l0bar:=time
    if timeframe.change(_htf)
        _o1:=_o0[1]; _h1:=_h0[1]; _l1:=_l0[1]; _t1:=_t0[1]; _c1:=close[1]
        _h1bar:=_h0bar[1]; _l1bar:=_l0bar[1]
    _c0:=close
    [_h1,_l1,_c1,_o1,_t1,_h0,_l0,_c0,_o0,_t0,_h1bar,_l1bar,_h0bar,_l0bar]

f_control(_mtf,_htf,hsmt,lsmt) =>
    var bear_cisd=false, var bear_level=open, var bear_index=bar_index
    var bull_cisd=false, var bull_level=open, var bull_index=bar_index
    var mtf_h=array.new_float(), var mtf_l=array.new_float()
    var mtf_o=array.new_float(), var mtf_c=array.new_float()
    var mtf_t=array.new_int(),   var mtf_hbar=array.new_int()
    var mtf_lbar=array.new_int(), var mtf_candle=array.new_int()
    var mup1=false, var mdw1=false, var meq1=false

    [mh1,ml1,mc1,mo1,mt1,mh0,ml0,mc0,mo0,mt0,mh1bar,ml1bar,mh0bar,ml0bar]=f_live_mini(_mtf)
    [hth1,htl1,htc1,hto1,htt1,hth0,htl0,htc0,hto0,htt0,hth1bar,htl1bar,hth0bar,htl0bar]=f_live_mini(_htf)

    mup=mc0>mo0; mdw=mc0<mo0; meq=mc0==mo0
    if timeframe.change(_mtf)
        add_to_array(mtf_h,mh1); add_to_array(mtf_l,ml1)
        add_to_array(mtf_o,mo1); add_to_array(mtf_c,mc1)
        add_to_array(mtf_t,mt1); add_to_array(mtf_hbar,mh1bar)
        add_to_array(mtf_lbar,ml1bar)
        mup1:=mup[1]; mdw1:=mdw[1]; meq1:=meq[1]
        add_to_array(mtf_candle,mup1 ? 1 : mdw1 ? -1 : 0)

    if mh0==hth0 and high==mh0 and mh0>=mh1
        bear_cisd:=false
        if (mdw1 or meq1) and mup
            bear_level:=mo0; bear_index:=mt0
        if ((mdw1 or meq1) and mup)==false and array.size(mtf_h)>15
            for i=1 to 15
                if array.get(mtf_h,i)>mh0
                    break
                if (array.get(mtf_candle,i)==-1 or array.get(mtf_candle,i)==0) and array.get(mtf_candle,i-1)==1
                    ybar=i-1
                    bear_level:=array.get(mtf_o,ybar); bear_index:=array.get(mtf_t,ybar)
                    for j=ybar to 0
                        if array.get(mtf_o,j)<bear_level and array.get(mtf_candle,j)==1
                            bear_level:=array.get(mtf_o,j); bear_index:=array.get(mtf_t,j)
                    if bear_level>mo0 and not (mc0<mo0) => bear_level:=mo0; bear_index:=time
                    if bear_level>mo0 and (mc0<mo0)     => bear_level:=ml0; bear_index:=time
                    break

    if ml0==htl0 and low==ml0 and ml0<=ml1
        bull_cisd:=false
        if (mup1 or meq1) and mdw
            bull_level:=mo0; bull_index:=mt0
        if ((mup1 or meq1) and mdw)==false and array.size(mtf_l)>15
            for i=1 to 15
                if array.get(mtf_l,i)<ml0
                    break
                if (array.get(mtf_candle,i)==1 or array.get(mtf_candle,i)==0) and array.get(mtf_candle,i-1)==-1
                    xbar=i-1
                    bull_level:=array.get(mtf_o,xbar); bull_index:=array.get(mtf_t,xbar)
                    for j=xbar to 0
                        if array.get(mtf_o,j)>bull_level and array.get(mtf_candle,j)==-1
                            bull_level:=array.get(mtf_o,j); bull_index:=array.get(mtf_t,j)
                    if bull_level<mo0 and not (mc0>mo0) => bull_level:=mo0; bull_index:=time
                    if bull_level<mo0 and (mc0>mo0)     => bull_level:=mh0; bull_index:=time
                    break

    [bear_level,bear_index,bull_level,bull_index]

// ═══════════════════════════════════════════════════════════════
// NEW — T-SPORT
// T-Sport = horizontal line drawn from a key price level
// extending to the right, acting as a "rail" for price to react
//
// Three anchor modes (all active simultaneously if enabled):
//   1. CISD anchor  — from the CISD level (bull or bear)
//   2. SMT trigger  — fires when SMT signal detected; anchor = swing
//   3. HTF High/Low — from the high/low of last confirmed HTF candle
//
// Lines extend `tsport_extend` bars to the right.
// Bull T-Sport drawn from bull CISD / bull SMT swing low / HTF low
// Bear T-Sport drawn from bear CISD / bear SMT swing high / HTF high
// ═══════════════════════════════════════════════════════════════

f_tsport_cisd(_ctf,_htf,_tfok,hsmt,lsmt) =>
    [pbecisd,be_index,pbucisd,bu_index]=f_control(_ctf,_htf,hsmt,lsmt)
    var line ts_bull_cisd = na
    var line ts_bear_cisd = na
    var label ts_bull_lbl = na
    var label ts_bear_lbl = na
    int x2 = bar_index + tsport_extend

    if show_tsport and tsport_cisd and tf_ok(_ctf) and _tfok and (barstate.islast or barstate.isrealtime)
        // Bullish T-Sport from bull CISD level
        if show_bucisd
            line.delete(ts_bull_cisd)
            label.delete(ts_bull_lbl)
            ts_bull_cisd := line.new(bar_index, pbucisd, x2, pbucisd,
                 xloc=xloc.bar_index, color=tsport_clr_bull,
                 style=tsport_style, width=tsport_width)
            ts_bull_lbl  := label.new(x2, pbucisd,
                 "T+ " + f_text(_ctf),
                 xloc=xloc.bar_index, color=color.new(tsport_clr_bull,80),
                 textcolor=tsport_clr_bull, style=label.style_label_left, size=size.tiny)
        // Bearish T-Sport from bear CISD level
        if show_becisd
            line.delete(ts_bear_cisd)
            label.delete(ts_bear_lbl)
            ts_bear_cisd := line.new(bar_index, pbecisd, x2, pbecisd,
                 xloc=xloc.bar_index, color=tsport_clr_bear,
                 style=tsport_style, width=tsport_width)
            ts_bear_lbl  := label.new(x2, pbecisd,
                 "T- " + f_text(_ctf),
                 xloc=xloc.bar_index, color=color.new(tsport_clr_bear,80),
                 textcolor=tsport_clr_bear, style=label.style_label_left, size=size.tiny)

// SMT-triggered T-Sport: fires once when SMT is detected
// Uses the swing high (bear) or swing low (bull) of the SMT bar as anchor
f_tsport_smt_draw(_bull_smt, _bear_smt) =>
    var line ts_smt_bull = na
    var line ts_smt_bear = na
    var label ts_smt_bull_lbl = na
    var label ts_smt_bear_lbl = na
    var bool  smt_bull_drawn  = false
    var bool  smt_bear_drawn  = false
    var int   smt_bull_bar    = 0
    var int   smt_bear_bar    = 0

    // Reset when SMT recurs on new bar
    if _bull_smt and bar_index != smt_bull_bar
        smt_bull_drawn := false
        smt_bull_bar   := bar_index
    if _bear_smt and bar_index != smt_bear_bar
        smt_bear_drawn := false
        smt_bear_bar   := bar_index

    int x2 = bar_index + tsport_extend
    if show_tsport and tsport_smt and (barstate.islast or barstate.isrealtime)
        if _bull_smt and not smt_bull_drawn
            line.delete(ts_smt_bull)
            label.delete(ts_smt_bull_lbl)
            ts_smt_bull     := line.new(bar_index, low, x2, low,
                 xloc=xloc.bar_index, color=tsport_clr_bull,
                 style=line.style_solid, width=tsport_width + 1)
            ts_smt_bull_lbl := label.new(x2, low,
                 "T-SMT ↑",
                 xloc=xloc.bar_index, color=color.new(tsport_clr_bull,70),
                 textcolor=tsport_clr_bull, style=label.style_label_left, size=size.tiny)
            smt_bull_drawn  := true

        if _bear_smt and not smt_bear_drawn
            line.delete(ts_smt_bear)
            label.delete(ts_smt_bear_lbl)
            ts_smt_bear     := line.new(bar_index, high, x2, high,
                 xloc=xloc.bar_index, color=tsport_clr_bear,
                 style=line.style_solid, width=tsport_width + 1)
            ts_smt_bear_lbl := label.new(x2, high,
                 "T-SMT ↓",
                 xloc=xloc.bar_index, color=color.new(tsport_clr_bear,70),
                 textcolor=tsport_clr_bear, style=label.style_label_left, size=size.tiny)
            smt_bear_drawn  := true

// HTF High/Low T-Sport: static rails from last confirmed HTF candle extremes
f_tsport_htf() =>
    var line ts_htf_high = na
    var line ts_htf_low  = na
    var label ts_htf_high_lbl = na
    var label ts_htf_low_lbl  = na
    int x2 = bar_index + tsport_extend
    if show_tsport and tsport_htf and (barstate.islast or barstate.isrealtime)
        line.delete(ts_htf_high); label.delete(ts_htf_high_lbl)
        line.delete(ts_htf_low);  label.delete(ts_htf_low_lbl)
        ts_htf_high     := line.new(bar_index, ph1, x2, ph1,
             xloc=xloc.bar_index, color=tsport_clr_bear,
             style=line.style_dotted, width=tsport_width)
        ts_htf_high_lbl := label.new(x2, ph1,
             "T-HTF H  " + str.tostring(math.round(ph1,2)),
             xloc=xloc.bar_index, color=color.new(tsport_clr_bear,80),
             textcolor=tsport_clr_bear, style=label.style_label_left, size=size.tiny)
        ts_htf_low      := line.new(bar_index, pl1, x2, pl1,
             xloc=xloc.bar_index, color=tsport_clr_bull,
             style=line.style_dotted, width=tsport_width)
        ts_htf_low_lbl  := label.new(x2, pl1,
             "T-HTF L  " + str.tostring(math.round(pl1,2)),
             xloc=xloc.bar_index, color=color.new(tsport_clr_bull,80),
             textcolor=tsport_clr_bull, style=label.style_label_left, size=size.tiny)

// ═══════════════════════════════════════════════════════════════
// NEW — LIQUIDITY SWEEP ENTRY SIGNALS
// Three modes shown simultaneously:
//   A. Full Confluence : Sweep + CISD confirm + SMT divergence
//   B. Sweep + CISD   : sweep occurred AND price confirmed CISD
//   C. Sweep + SMT    : sweep occurred AND SMT divergence present
//
// Entry signal = label + background bar color at the trigger bar
// ═══════════════════════════════════════════════════════════════

// We need CISD confirm state — track whether price crossed CISD level
// Using the active CISD levels from the primary CISD TF (ctf7 / tf7 pair as default)
// Trader can watch all TFs; we compute for the most granular active pair
[cisd_be7,cisd_be_idx7,cisd_bu7,cisd_bu_idx7]=f_control(ctf7,tf7,tf7_bull_smt,tf7_bear_smt)
[cisd_be6,cisd_be_idx6,cisd_bu6,cisd_bu_idx6]=f_control(ctf6,tf6,tf6_bull_smt,tf6_bear_smt)
[cisd_be4,cisd_be_idx4,cisd_bu4,cisd_bu_idx4]=f_control(ctf4,tf4,tf4_bull_smt,tf4_bear_smt)

// CISD confirmation: close has crossed the CISD level
bool cisd_bull_confirm = (close > cisd_bu7 and close[1] <= cisd_bu7) or
                         (close > cisd_bu6 and close[1] <= cisd_bu6) or
                         (close > cisd_bu4 and close[1] <= cisd_bu4)
bool cisd_bear_confirm = (close < cisd_be7 and close[1] >= cisd_be7) or
                         (close < cisd_be6 and close[1] >= cisd_be6) or
                         (close < cisd_be4 and close[1] >= cisd_be4)

// Mode A: Full Confluence
bool entry_bull_full = any_xl_sweep and cisd_bull_confirm and any_bull_smt and show_entry and entry_mode_full
bool entry_bear_full = any_xh_sweep and cisd_bear_confirm and any_bear_smt and show_entry and entry_mode_full

// Mode B: Sweep + CISD only
bool entry_bull_sw_cs = any_xl_sweep and cisd_bull_confirm and not any_bull_smt and show_entry and entry_mode_sw_cs
bool entry_bear_sw_cs = any_xh_sweep and cisd_bear_confirm and not any_bear_smt and show_entry and entry_mode_sw_cs

// Mode C: Sweep + SMT only
bool entry_bull_sw_sm = any_xl_sweep and any_bull_smt and not cisd_bull_confirm and show_entry and entry_mode_sw_sm
bool entry_bear_sw_sm = any_xh_sweep and any_bear_smt and not cisd_bear_confirm and show_entry and entry_mode_sw_sm

// Draw entry labels
if entry_bull_full
    label.new(bar_index, low,
         "▲ FULL\nSWP+CISD+SMT",
         color=color.new(entry_bull_clr,20),
         textcolor=color.white, style=label.style_label_up, size=entry_label_size)
if entry_bear_full
    label.new(bar_index, high,
         "▼ FULL\nSWP+CISD+SMT",
         color=color.new(entry_bear_clr,20),
         textcolor=color.white, style=label.style_label_down, size=entry_label_size)

if entry_bull_sw_cs
    label.new(bar_index, low,
         "▲ B\nSWP+CISD",
         color=color.new(entry_bull_clr,40),
         textcolor=color.white, style=label.style_label_up, size=entry_label_size)
if entry_bear_sw_cs
    label.new(bar_index, high,
         "▼ B\nSWP+CISD",
         color=color.new(entry_bear_clr,40),
         textcolor=color.white, style=label.style_label_down, size=entry_label_size)

if entry_bull_sw_sm
    label.new(bar_index, low,
         "▲ C\nSWP+SMT",
         color=color.new(entry_bull_clr,55),
         textcolor=color.white, style=label.style_label_up, size=entry_label_size)
if entry_bear_sw_sm
    label.new(bar_index, high,
         "▼ C\nSWP+SMT",
         color=color.new(entry_bear_clr,55),
         textcolor=color.white, style=label.style_label_down, size=entry_label_size)

// Alerts for entry signals
alertcondition(entry_bull_full, "🟢 Full Confluence Bull", "Full Bull Entry: Sweep + CISD + SMT confirmed ↑")
alertcondition(entry_bear_full, "🔴 Full Confluence Bear", "Full Bear Entry: Sweep + CISD + SMT confirmed ↓")
alertcondition(entry_bull_sw_cs, "🟢 Sweep+CISD Bull", "Bull Entry: Sweep + CISD confirmed ↑")
alertcondition(entry_bear_sw_cs, "🔴 Sweep+CISD Bear", "Bear Entry: Sweep + CISD confirmed ↓")
alertcondition(entry_bull_sw_sm, "🟢 Sweep+SMT Bull", "Bull Entry: Sweep + SMT divergence ↑")
alertcondition(entry_bear_sw_sm, "🔴 Sweep+SMT Bear", "Bear Entry: Sweep + SMT divergence ↓")

// ── Entry Table ────────────────────────────────────────────────
var table entry_tbl = na
if show_entry and show_entry_table and (barstate.islast or barstate.isrealtime)
    if na(entry_tbl)
        entry_tbl := table.new(position.bottom_left, 3, 5,
             bgcolor=color.new(#0D0D1A,10),
             border_color=color.new(color.white,70), border_width=1,
             frame_color=color.new(color.white,60), frame_width=1)

    // Header
    table.cell(entry_tbl,0,0,"Entry Mode",        text_color=color.white, bgcolor=color.new(#1A237E,20), text_size=size.tiny)
    table.cell(entry_tbl,1,0,"Bull ↑",             text_color=#00E676,     bgcolor=color.new(#1A237E,20), text_size=size.tiny)
    table.cell(entry_tbl,2,0,"Bear ↓",             text_color=#FF1744,     bgcolor=color.new(#1A237E,20), text_size=size.tiny)

    table.cell(entry_tbl,0,1,"A: Full (S+C+M)",    text_color=color.white, bgcolor=color.new(#0D0D1A,40), text_size=size.tiny)
    table.cell(entry_tbl,1,1, entry_bull_full ? "✓ ACTIVE" : "—",
         text_color=entry_bull_full ? #00E676 : color.gray,
         bgcolor=entry_bull_full ? color.new(#00E676,80) : color.new(#0D0D1A,40), text_size=size.tiny)
    table.cell(entry_tbl,2,1, entry_bear_full ? "✓ ACTIVE" : "—",
         text_color=entry_bear_full ? #FF1744 : color.gray,
         bgcolor=entry_bear_full ? color.new(#FF1744,80) : color.new(#0D0D1A,40), text_size=size.tiny)

    table.cell(entry_tbl,0,2,"B: Sweep+CISD",      text_color=color.white, bgcolor=color.new(#0D0D1A,40), text_size=size.tiny)
    table.cell(entry_tbl,1,2, entry_bull_sw_cs ? "✓ ACTIVE" : "—",
         text_color=entry_bull_sw_cs ? #00E676 : color.gray,
         bgcolor=entry_bull_sw_cs ? color.new(#00E676,80) : color.new(#0D0D1A,40), text_size=size.tiny)
    table.cell(entry_tbl,2,2, entry_bear_sw_cs ? "✓ ACTIVE" : "—",
         text_color=entry_bear_sw_cs ? #FF1744 : color.gray,
         bgcolor=entry_bear_sw_cs ? color.new(#FF1744,80) : color.new(#0D0D1A,40), text_size=size.tiny)

    table.cell(entry_tbl,0,3,"C: Sweep+SMT",       text_color=color.white, bgcolor=color.new(#0D0D1A,40), text_size=size.tiny)
    table.cell(entry_tbl,1,3, entry_bull_sw_sm ? "✓ ACTIVE" : "—",
         text_color=entry_bull_sw_sm ? #00E676 : color.gray,
         bgcolor=entry_bull_sw_sm ? color.new(#00E676,80) : color.new(#0D0D1A,40), text_size=size.tiny)
    table.cell(entry_tbl,2,3, entry_bear_sw_sm ? "✓ ACTIVE" : "—",
         text_color=entry_bear_sw_sm ? #FF1744 : color.gray,
         bgcolor=entry_bear_sw_sm ? color.new(#FF1744,80) : color.new(#0D0D1A,40), text_size=size.tiny)

    // Projection snapshot
    table.cell(entry_tbl,0,4,"Proj (50/100/-100)", text_color=color.silver, bgcolor=color.new(#0D0D1A,40), text_size=size.tiny)
    table.cell(entry_tbl,1,4,
         str.tostring(math.round(level_50,2)) + " / " + str.tostring(math.round(level_100,2)),
         text_color=#FFD700, bgcolor=color.new(#0D0D1A,40), text_size=size.tiny)
    table.cell(entry_tbl,2,4,
         str.tostring(math.round(level_neg100,2)),
         text_color=#F44336, bgcolor=color.new(#0D0D1A,40), text_size=size.tiny)

// ═══════════════════════════════════════════════════════════════
// T-SPORT DRAW CALLS (per active CISD TF)
// ═══════════════════════════════════════════════════════════════
if ctfok1 and tf_ok(ctf1) => f_tsport_cisd(ctf1,tf1,ctfok1,tf1_bull_smt,tf1_bear_smt)
if ctfok2 and tf_ok(ctf2) => f_tsport_cisd(ctf2,tf2,ctfok2,tf2_bull_smt,tf2_bear_smt)
if ctfok3 and tf_ok(ctf3) => f_tsport_cisd(ctf3,tf3,ctfok3,tf3_bull_smt,tf3_bear_smt)
if ctfok4 and tf_ok(ctf4) => f_tsport_cisd(ctf4,tf4,ctfok4,tf4_bull_smt,tf4_bear_smt)
if ctfok5 and tf_ok(ctf5) => f_tsport_cisd(ctf5,tf5,ctfok5,tf5_bull_smt,tf5_bear_smt)
if ctfok6 and tf_ok(ctf6) => f_tsport_cisd(ctf6,tf6,ctfok6,tf6_bull_smt,tf6_bear_smt)
if ctfok7 and tf_ok(ctf7) => f_tsport_cisd(ctf7,tf7,ctfok7,tf7_bull_smt,tf7_bear_smt)
if ctfok8 and tf_ok(ctf8) => f_tsport_cisd(ctf8,tf8,ctfok8,tf8_bull_smt,tf8_bear_smt)
if ctfok9 and tf_ok(ctf9) => f_tsport_cisd(ctf9,tf9,ctfok9,tf9_bull_smt,tf9_bear_smt)

// SMT T-Sport (aggregate signal)
f_tsport_smt_draw(any_bull_smt, any_bear_smt)

// HTF T-Sport
f_tsport_htf()

// ═══════════════════════════════════════════════════════════════
// ORIGINAL CISD PLOT + CONFIRM
// ═══════════════════════════════════════════════════════════════
f_cisd_plot(_ctf,_htf,_tfok,hsmt,lsmt) =>
    [pbecisd,be_index,pbucisd,bu_index]=f_control(_ctf,_htf,hsmt,lsmt)
    dt=timeframe.in_seconds(tf)*1000
    cisd_opt=show_tfcisd ? tf==_ctf : true
    var pbu_line=line.new(na,na,na,na), var pbe_line=line.new(na,na,na,na)
    var pbu_lbl=label.new(na,na),       var pbe_lbl=label.new(na,na)
    if tf_ok(_ctf) and _tfok and show_bucisd and cisd_opt
        pbu_line:=line.new(x1=bu_index,y1=pbucisd,x2=time+5*dt,y2=pbucisd,xloc=xloc.bar_time,color=bucsd_clr,width=1,style=csd_style)
        pbu_lbl :=label.new(x=time+5*dt,y=pbucisd,text=f_text(_ctf)+" +",xloc=xloc.bar_time,color=color.new(color.white,100),style=label.style_label_left,textcolor=bucsd_clr,size=i_font)
        line.delete(pbu_line[1]); label.delete(pbu_lbl[1])
    if tf_ok(_ctf) and _tfok and show_becisd and cisd_opt
        pbe_line:=line.new(x1=be_index,y1=pbecisd,x2=time+5*dt,y2=pbecisd,xloc=xloc.bar_time,color=becsd_clr,width=1,style=csd_style)
        pbe_lbl :=label.new(x=time+5*dt,y=pbecisd,text=f_text(_ctf)+" -",xloc=xloc.bar_time,color=color.new(color.white,100),style=label.style_label_left,textcolor=becsd_clr,size=i_font)
        line.delete(pbe_line[1]); label.delete(pbe_lbl[1])

f_cisd_confirme(_ctf,_htf,_tfok,hsmt,lsmt) =>
    [pbecisd,pbe_index,pbucisd,pbu_index]=f_control(_ctf,_htf,hsmt,lsmt)
    [hth1,htl1,htc1,hto1,htt1,hth0,htl0,htc0,hto0,htt0,hth1bar,htl1bar,hth0bar,htl0bar]=f_live_mini(_ctf)
    var bear_cisd=false, var bull_cisd=false
    var cpbu_line=line.new(na,na,na,na), var cpbe_line=line.new(na,na,na,na)
    if pbecisd!=pbecisd[1] => bear_cisd:=false
    if pbucisd!=pbucisd[1] => bull_cisd:=false
    if htc1<pbecisd and tf_ok(_ctf) and _tfok and bear_cisd==false and time>pbe_index
        cpbe_line:=line.new(x1=pbe_index,y1=pbecisd,x2=htt1,y2=pbecisd,xloc=xloc.bar_time,color=becsd_clr,width=3,style=line.style_solid)
        line.delete(cpbe_line[1]); bear_cisd:=true
    if htc1>pbucisd and tf_ok(_ctf) and _tfok and bull_cisd==false and time>pbu_index
        cpbu_line:=line.new(x1=pbu_index,y1=pbucisd,x2=htt1,y2=pbucisd,xloc=xloc.bar_time,color=bucsd_clr,width=3,style=line.style_solid)
        line.delete(cpbu_line[1]); bull_cisd:=true

f_cisd_plot(ctf1,tf1,ctfok1,tf1_bull_smt,tf1_bear_smt)
f_cisd_plot(ctf2,tf2,ctfok2,tf2_bull_smt,tf2_bear_smt)
f_cisd_plot(ctf3,tf3,ctfok3,tf3_bull_smt,tf3_bear_smt)
f_cisd_plot(ctf4,tf4,ctfok4,tf4_bull_smt,tf4_bear_smt)
f_cisd_plot(ctf5,tf5,ctfok5,tf5_bull_smt,tf5_bear_smt)
f_cisd_plot(ctf6,tf6,ctfok6,tf6_bull_smt,tf6_bear_smt)
f_cisd_plot(ctf7,tf7,ctfok7,tf7_bull_smt,tf7_bear_smt)
f_cisd_plot(ctf8,tf8,ctfok8,tf8_bull_smt,tf8_bear_smt)
f_cisd_plot(ctf9,tf9,ctfok9,tf9_bull_smt,tf9_bear_smt)

if tf==ctf1 => f_cisd_confirme(ctf1,tf1,ctfok1,tf1_bull_smt,tf1_bear_smt)
if tf==ctf2 => f_cisd_confirme(ctf2,tf2,ctfok2,tf2_bull_smt,tf2_bear_smt)
if tf==ctf3 => f_cisd_confirme(ctf3,tf3,ctfok3,tf3_bull_smt,tf3_bear_smt)
if tf==ctf4 => f_cisd_confirme(ctf4,tf4,ctfok4,tf4_bull_smt,tf4_bear_smt)
if tf==ctf5 => f_cisd_confirme(ctf5,tf5,ctfok5,tf5_bull_smt,tf5_bear_smt)
if tf==ctf6 => f_cisd_confirme(ctf6,tf6,ctfok6,tf6_bull_smt,tf6_bear_smt)
if tf==ctf7 => f_cisd_confirme(ctf7,tf7,ctfok7,tf7_bull_smt,tf7_bear_smt)
if tf==ctf8 => f_cisd_confirme(ctf8,tf8,ctfok8,tf8_bull_smt,tf8_bear_smt)
if tf==ctf9 => f_cisd_confirme(ctf9,tf9,ctfok9,tf9_bull_smt,tf9_bear_smt)

// ═══════════════════════════════════════════════════════════════
// ORIGINAL SMT TABLE + CANDLES
// ═══════════════════════════════════════════════════════════════
if timeframe.in_seconds(tf)>=timeframe.in_seconds("1")
    if show_smt_table and asset_ok
        table.cell(tablo2,0,0,text="SMT",     text_color=i_textcolor,bgcolor=i_main_clr,text_size=i_font)
        table.cell(tablo2,1,0,text="Bullish", text_color=i_textcolor,bgcolor=i_main_clr,text_size=i_font)
        table.cell(tablo2,2,0,text="Bearish", text_color=i_textcolor,bgcolor=i_main_clr,text_size=i_font)
    if show_swe_table
        table.cell(tablo2,3,0,text="SWP",     text_color=i_textcolor,bgcolor=i_main_clr,text_size=i_font)
        table.cell(tablo2,4,0,text="Bullish", text_color=i_textcolor,bgcolor=i_main_clr,text_size=i_font)
        table.cell(tablo2,5,0,text="Bearish", text_color=i_textcolor,bgcolor=i_main_clr,text_size=i_font)
        table.cell(tablo2,6,0,text="Go",      text_color=i_textcolor,bgcolor=i_main_clr,text_size=i_font)

    f_row(_idx,_tfok_v,_tf_str,_bull_smt,_bear_smt,_xl_sw,_cl_sw,_xh_sw,_ch_sw,_look) =>
        if _tfok_v and tf_ok(_tf_str)
            if show_smt_table and asset_ok
                table.cell(tablo2,0,_idx,text=f_text(_tf_str),      text_color=i_textcolor,bgcolor=i_title_clr,text_size=i_font)
                table.cell(tablo2,1,_idx,text=f_smt_txt(_bull_smt), text_color=i_textcolor,bgcolor=i_bgcolor,  text_size=size.normal)
                table.cell(tablo2,2,_idx,text=f_smt_txt(_bear_smt), text_color=i_textcolor,bgcolor=i_bgcolor,  text_size=size.normal)
            if show_swe_table
                table.cell(tablo2,3,_idx,text=f_text(_tf_str),           text_color=i_textcolor,bgcolor=i_title_clr,text_size=i_font)
                table.cell(tablo2,4,_idx,text=f_swp_txt(_xl_sw,_cl_sw),  text_color=i_textcolor,bgcolor=i_bgcolor,  text_size=size.normal)
                table.cell(tablo2,5,_idx,text=f_swp_txt(_xh_sw,_ch_sw),  text_color=i_textcolor,bgcolor=i_bgcolor,  text_size=size.normal)
                table.cell(tablo2,6,_idx,text=_look,                      text_color=i_textcolor,bgcolor=i_title_clr,text_size=i_font)

    f_row(1,tfok1,tf1,tf1_bull_smt,tf1_bear_smt,tf1_xl_sweep,tf1_cl_sweep,tf1_xh_sweep,tf1_ch_sweep,f_look_tf(tf1))
