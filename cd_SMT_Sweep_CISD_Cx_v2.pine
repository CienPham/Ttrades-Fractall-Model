ctf9 = input.timeframe(defval="1",   title="cisd tf:", group=g1, inline="9")

tfok1 = input.bool(defval=false, title="", group=g1, inline="1")
tfok2 = input.bool(defval=false, title="", group=g1, inline="2")
tfok3 = input.bool(defval=false, title="", group=g1, inline="3")
